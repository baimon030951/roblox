local function collectAmmoBox(box)
    local rootPart = getRootPart()
    if not rootPart or not box then
        return false
    end

    local targetCFrame, targetSize = getTargetTransform(box)
    if not targetCFrame then
        return false
    end

    local yOffset = targetSize and (targetSize.Y * 0.5 + 3) or 3
    rootPart.CFrame = targetCFrame * CFrame.new(0, yOffset, 0)
    task.wait(0.15)

    local prompt = box:FindFirstChildWhichIsA("ProximityPrompt", true)
    if not prompt then
        return false
    end

    if fireproximityprompt then
        pcall(function()
            fireproximityprompt(prompt)
        end)
        return true
    end

    local ok = pcall(function()
        prompt:InputHoldBegin()
        task.wait((prompt.HoldDuration or 0) + 0.15)
        prompt:InputHoldEnd()
    end)

    return ok
end

local function collectTransformerBox(target)
    local rootPart = getRootPart()
    if not rootPart or not target then
        return false
    end

    local targetCFrame, targetSize = getTargetTransform(target)
    if not targetCFrame then
        return false
    end

    local yOffset = targetSize and (targetSize.Y * 0.5 + 3) or 3
    rootPart.CFrame = targetCFrame * CFrame.new(0, yOffset, 0)
    task.wait(0.2)

    local startedMiniGame = false
    local timeoutAt = tick() + 4
    local keyHeld = false

    pcall(function()
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        keyHeld = true
    end)

    while autoTransformerBoxEnabled and tick() < timeoutAt do
        if hasRepairMiniGame() then
            startedMiniGame = true
            break
        end
        task.wait(0.05)
    end

    if keyHeld then
        pcall(function()
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        end)
    end

    return startedMiniGame
end

