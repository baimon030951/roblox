local CarConfig = {
    ExcludedCars    = {},
    WheelSize       = Vector3.new(10, 10, 10),
    Enabled         = false,
    HighlightEnabled = true,
    HighlightColor  = Color3.fromRGB(255, 165, 0),
}

local function GetAllCars()
    local t = {}
    local keepCar = workspace:FindFirstChild("KeepCar")
    if not keepCar then return t end
    for _, car in pairs(keepCar:GetChildren()) do
        table.insert(t, car.Name)
    end
    return t
end

local function ApplyWheelSize(size)
    local keepCar = workspace:FindFirstChild("KeepCar")
    if not keepCar then
        Notify("ผิดพลาด", "ไม่พบ KeepCar ใน workspace", "alert-triangle")
        return 0
    end

    local excludeList = {}
    for _, name in pairs(CarConfig.ExcludedCars) do
        excludeList[name] = true
    end

    local count = 0
    local suspNames = { "SuspensionFL", "SuspensionFR", "SuspensionRL", "SuspensionRR" }

    for _, car in pairs(keepCar:GetChildren()) do
        if excludeList[car.Name] then continue end
        local chassis = car:FindFirstChild("Chassis")
        if not chassis then continue end

        for _, suspName in ipairs(suspNames) do
            local susp = chassis:FindFirstChild(suspName)
            if not susp then continue end

            -- หา Wheel
            local wheel = susp:FindFirstChild("Wheel")
            if not wheel then
                for _, desc in pairs(susp:GetDescendants()) do
                    if desc:IsA("BasePart") then
                        wheel = desc
                        break
                    end
                end
            end
            if not wheel then continue end

            -- ปรับ Size
            pcall(function() wheel.Size = size end)

            -- Highlight ติดที่ wheel โดยตรง ใช้ SelectionBox แทนถ้า Highlight ไม่ขึ้น
            -- ลบ highlight/selectionbox เก่าออกก่อน
            for _, old in pairs(wheel:GetChildren()) do
                if old:IsA("Highlight") or old:IsA("SelectionBox") then
                    old:Destroy()
                end
            end

            if CarConfig.HighlightEnabled then
                -- ใช้ทั้ง Highlight และ SelectionBox เหมือนระบบ hitbox คน
                local hl = Instance.new("Highlight")
                hl.Adornee             = wheel
                hl.FillColor           = CarConfig.HighlightColor
                hl.OutlineColor        = CarConfig.HighlightColor
                hl.FillTransparency    = 0.5
                hl.OutlineTransparency = 0
                hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
                hl.Enabled             = true
                hl.Parent              = wheel

                local sb = Instance.new("SelectionBox")
                sb.Adornee       = wheel
                sb.Color3        = CarConfig.HighlightColor
                sb.LineThickness = 0.05
                sb.Transparency  = 0
                sb.Visible       = true
                sb.Parent        = wheel
            end

            count += 1
        end
    end

    if count == 0 then
        Notify("คำเตือน", "ไม่พบล้อในรถ", "alert-triangle")
    end

    return count
end

local function ResetWheelSize()
    local keepCar = workspace:FindFirstChild("KeepCar")
    if not keepCar then return end
    local suspNames = { "SuspensionFL", "SuspensionFR", "SuspensionRL", "SuspensionRR" }
    for _, car in pairs(keepCar:GetChildren()) do
        local chassis = car:FindFirstChild("Chassis")
        if not chassis then continue end
        for _, suspName in ipairs(suspNames) do
            local susp = chassis:FindFirstChild(suspName)
            if not susp then continue end
            local wheel = susp:FindFirstChild("Wheel")
            if not wheel then
                for _, desc in pairs(susp:GetDescendants()) do
                    if desc:IsA("BasePart") then wheel = desc break end
                end
            end
            if not wheel then continue end
            pcall(function() wheel.Size = Vector3.new(3, 3, 3) end)
            for _, old in pairs(wheel:GetChildren()) do
                if old:IsA("Highlight") or old:IsA("SelectionBox") then
                    old:Destroy()
                end
            end
        end
    end
end

