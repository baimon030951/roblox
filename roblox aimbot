    WheelConnections = {}
end

local function HookWheels(size)
    ClearWheelConnections()
    local keepCar = workspace:FindFirstChild("KeepCar")
    if not keepCar then return end

    local excludeList = {}
    for _, name in pairs(CarConfig.ExcludedCars) do excludeList[name] = true end

    local suspNames = { "SuspensionFL", "SuspensionFR", "SuspensionRL", "SuspensionRR" }

    for _, car in pairs(keepCar:GetChildren()) do
        if excludeList[car.Name] then continue end
        local chassis = car:FindFirstChild("Chassis")
        if not chassis then continue end

        for _, suspName in ipairs(suspNames) do
            local susp = chassis:FindFirstChild(suspName)
            if not susp then continue end

            local wheel = susp:FindFirstChild("Wheel")
            if not wheel then
                for _, desc in pairs(susp:GetDescendants()) do
                    if desc:IsA("BasePart") then wheel = desc break end
                end
            end
            if not wheel then continue end

            -- Hook ทันทีที่ Size ถูกเปลี่ยน ก็ set กลับทันที
            local conn = wheel:GetPropertyChangedSignal("Size"):Connect(function()
                if CarConfig.Enabled and wheel.Size ~= size then
                    pcall(function() wheel.Size = size end)
                end
            end)
            table.insert(WheelConnections, conn)
        end
    end
end

