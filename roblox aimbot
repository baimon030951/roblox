-- [Fix 14]
local function SafeRGB(r, g, b)
	return Color3.fromRGB(
		math.clamp(math.floor(r), 0, 255),
		math.clamp(math.floor(g), 0, 255),
		math.clamp(math.floor(b), 0, 255)
	)
end

local Tween = function(obj, spd, props, info)
	local sty = (info and info.EasingStyle)     or Enum.EasingStyle.Quint
	local dir = (info and info.EasingDirection) or Enum.EasingDirection.Out
	Services.Tween:Create(obj, TweenInfo.new(spd, sty, dir), props):Play()
end

local SetProperty = function(obj, props)
	for k, v in next, props do obj[k] = v end
	return obj
end

local Multiply = function(val, amt)
	return UDim2.new(
		val.X.Scale * amt,  val.X.Offset * amt,
		val.Y.Scale * amt,  val.Y.Offset * amt
	)
end

-- Drag
local Drag = function(canvas)
	if not canvas then return end
	local dragging, dragInput, start, startPos

	Connect(canvas.InputBegan, function(inp)
		if (inp.UserInputType == Enum.UserInputType.MouseButton1 or
		    inp.UserInputType == Enum.UserInputType.Touch) and not Type then
			dragging = true
			start    = inp.Position
			startPos = canvas.Position
			Connect(inp.Changed, function()
				if inp.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)
	Connect(canvas.InputChanged, function(inp)
		if (inp.UserInputType == Enum.UserInputType.MouseMovement or
		    inp.UserInputType == Enum.UserInputType.Touch) and not Type then
			dragInput = inp
		end
	end)
	Connect(Services.Input.InputChanged, function(inp)
		if inp == dragInput and dragging and not Type then
			local d = inp.Position - start
			canvas.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + d.X,
				startPos.Y.Scale, startPos.Y.Offset + d.Y
			)
		end
	end)
end

-- [Fix 1] local Resizing
local Resizing = {
	TopLeft     = { X = Vector2.new(-1, 0), Y = Vector2.new(0, -1) },
	TopRight    = { X = Vector2.new( 1, 0), Y = Vector2.new(0, -1) },
	BottomLeft  = { X = Vector2.new(-1, 0), Y = Vector2.new(0,  1) },
	BottomRight = { X = Vector2.new( 1, 0), Y = Vector2.new(0,  1) },
}

local Resizeable = function(tab, minSz, maxSz)
	task.spawn(function()
		local mousePos, size, uiPos
		local rf = tab:FindFirstChild("Resize")
		if not rf then return end

		for _, handle in next, rf:GetChildren() do
			Connect(handle.InputBegan, function(inp)
				if inp.UserInputType == Enum.UserInputType.MouseButton1 then
					Type     = handle
					mousePos = Vector2.new(Player.Mouse.X, Player.Mouse.Y)
					size     = tab.AbsoluteSize
					uiPos    = tab.Position
				end
			end)
			Connect(handle.InputEnded, function(inp)
				if inp.UserInputType == Enum.UserInputType.MouseButton1 then
					Type = nil
				end
			end)
		end

		Connect(Player.Mouse.Move, function()
			if not Type or not mousePos then return end
			if rf[Type.Name] ~= Type then return end

			local mode  = Resizing[Type.Name]
			local delta = Vector2.new(Player.Mouse.X, Player.Mouse.Y) - mousePos
			local newSz = Vector2.new(
				math.clamp(size.X + delta.X * mode.X.X, minSz.X, maxSz.X),
				math.clamp(size.Y + delta.Y * mode.Y.Y, minSz.Y, maxSz.Y)
			)
			local anchorD = Vector2.new(
				tab.AnchorPoint.X * (newSz.X - size.X),
				tab.AnchorPoint.Y * (newSz.Y - size.Y)
			)
			tab.Size = UDim2.new(0, newSz.X, 0, newSz.Y)
			tab.Position = UDim2.new(
				uiPos.X.Scale, uiPos.X.Offset + anchorD.X * mode.X.X,
				uiPos.Y.Scale, uiPos.Y.Offset + anchorD.Y * mode.Y.Y
			)
		end)
	end)
end

