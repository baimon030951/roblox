    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        window:RunSearch(searchBox.Text)
    end)

    closeButton.MouseButton1Click:Connect(function()
        tween(root, MidTween, {BackgroundTransparency = 1, Size = UDim2.fromOffset(root.AbsoluteSize.X - 20, root.AbsoluteSize.Y - 14)})
        task.delay(0.22, function()
            if self.ScreenGui.Parent then self.ScreenGui:Destroy() end
        end)
    end)
    minimizeButton.MouseButton1Click:Connect(function() window:ToggleVisible() end)
    maximizeButton.MouseButton1Click:Connect(function() window:SetMaximized(not window.Maximized) end)

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not gameProcessed and input.KeyCode == window.ToggleKey then window:ToggleVisible() end
    end)

    local function updateWindowSize(w, h)
        local cw = math.max(window.MinSize.X, math.floor(w+0.5))
        local ch = math.max(window.MinSize.Y, math.floor(h+0.5))
        window.Size = UDim2.fromOffset(cw, ch)
        root.Size   = window.Size
        window:RefreshSearchBox()
    end

    local resizeRight  = create("Frame", {Name="ResizeRight",  BackgroundTransparency=1, AnchorPoint=Vector2.new(1,0), Position=UDim2.new(1,0,0,12), Size=UDim2.new(0,7,1,-18), Parent=root})
    local resizeBottom = create("Frame", {Name="ResizeBottom", BackgroundTransparency=1, AnchorPoint=Vector2.new(0,1), Position=UDim2.new(0,12,1,0), Size=UDim2.new(1,-18,0,7), Parent=root})
    local resizeCorner = create("Frame", {Name="ResizeCorner", BackgroundTransparency=1, AnchorPoint=Vector2.new(1,1), Position=UDim2.new(1,0,1,0), Size=UDim2.fromOffset(14,14), Parent=root})

    local rsState = {Active=false, Mode=nil, StartMouse=nil, StartSize=nil}
    local function beginResize(mode, input)
        if window.Maximized then window:SetMaximized(false) end
        rsState.Active=true; rsState.Mode=mode
        rsState.StartMouse=input.Position; rsState.StartSize=root.AbsoluteSize
    end
    for mode, handle in pairs({Right=resizeRight, Bottom=resizeBottom, Corner=resizeCorner}) do
        handle.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then beginResize(mode, input) end
        end)
    end
    UserInputService.InputChanged:Connect(function(input)
        if not rsState.Active or input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local d = input.Position - rsState.StartMouse
        local w, h = rsState.StartSize.X, rsState.StartSize.Y
        if rsState.Mode == "Right"  or rsState.Mode == "Corner" then w = w + d.X end
        if rsState.Mode == "Bottom" or rsState.Mode == "Corner" then h = h + d.Y end
        updateWindowSize(w, h)
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then rsState.Active = false end
    end)

    root:GetPropertyChangedSignal("AbsoluteSize"):Connect(function() window:RefreshSearchBox() end)
    Workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
        if window.Maximized then root.Size = screenMaximizedSize() end
        window:RefreshSearchBox()
    end)

    tween(root, SlowTween, {Size = window.Size})
    window:RefreshSearchBox()
    return window
end

