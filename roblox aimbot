-- ============================================================
-- HELPERS
-- ============================================================
local function tween(obj, info, props)
    local t = TweenService:Create(obj, info, props) ; t:Play() ; return t
end

local function create(class, props)
    local obj = Instance.new(class)
    for k, v in pairs(props or {}) do obj[k] = v end
    return obj
end

local function corner(obj, r)
    create("UICorner", { CornerRadius = UDim.new(0, r or 8), Parent = obj })
end

local function stroke(obj, color, alpha, thick)
    create("UIStroke", {
        Color           = color or Theme.Outline,
        Transparency    = alpha or 0,
        Thickness       = thick or 1,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
        Parent          = obj,
    })
end

local function pad(obj, t, b, l, r)
    create("UIPadding", {
        PaddingTop    = UDim.new(0, t or 0),
        PaddingBottom = UDim.new(0, b or 0),
        PaddingLeft   = UDim.new(0, l or 0),
        PaddingRight  = UDim.new(0, r or 0),
        Parent        = obj,
    })
end

local function listLayout(obj, spacing, horizontal)
    return create("UIListLayout", {
        Padding       = UDim.new(0, spacing or 6),
        FillDirection = horizontal
            and Enum.FillDirection.Horizontal
            or  Enum.FillDirection.Vertical,
        SortOrder     = Enum.SortOrder.LayoutOrder,
        Parent        = obj,
    })
end

local function safeCall(fn, ...)
    if typeof(fn) ~= "function" then return end
    local ok, err = pcall(fn, ...) ; if not ok then warn("[Pulse]", err) end
end

-- macOS-style shadow: subtle, very soft
local function macShadow(parent)
    local s = create("Frame", {
        Name                   = "Shadow",
        BackgroundColor3       = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = 0.88,
        BorderSizePixel        = 0,
        Size                   = UDim2.new(1, 12, 1, 12),
        Position               = UDim2.new(0, -6, 0, -3),
        ZIndex                 = math.max(parent.ZIndex - 1, 0),
        Parent                 = parent,
    })
    corner(s, 18)
    return s
end

-- ripple (ใช้สีฟ้า แต่โปร่งใสมาก)
local function ripple(button)
    local clip = create("Frame", {
        BackgroundTransparency = 1,
        Size                   = UDim2.fromScale(1, 1),
        ClipsDescendants       = true,
        Parent                 = button,
    })
    corner(clip, 8)
    button.MouseButton1Down:Connect(function(x, y)
        local c = create("Frame", {
            AnchorPoint            = Vector2.new(0.5, 0.5),
            Position               = UDim2.fromOffset(
                x - button.AbsolutePosition.X,
                y - button.AbsolutePosition.Y
            ),
            Size                   = UDim2.fromOffset(0, 0),
            BackgroundColor3       = Theme.Accent,
            BackgroundTransparency = 0.88,
            BorderSizePixel        = 0,
            Parent                 = clip,
        })
        corner(c, 999)
        local goal = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 1.6
        tween(c, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Size                   = UDim2.fromOffset(goal, goal),
            BackgroundTransparency = 1,
        })
        task.delay(0.35, function() if c.Parent then c:Destroy() end end)
    end)
end

-- themed scrollbar
local function themedScrollbar(scroll, parent, pos, sz)
    scroll.ScrollBarThickness = 0
    local track = create("Frame", {
        BackgroundColor3 = Theme.Outline,
        BorderSizePixel  = 0,
        Position         = pos,
        Size             = sz,
        ZIndex           = 6,
        Parent           = parent,
    })
    corner(track, 999)
    local thumb = create("Frame", {
        BackgroundColor3 = Theme.Muted,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 0.2, 0),
        ZIndex           = 7,
        Parent           = track,
    })
    corner(thumb, 999)
    local function update()
        local cY = scroll.AbsoluteCanvasSize.Y
        local wY = scroll.AbsoluteWindowSize.Y
        if cY <= 0 or wY <= 0 or cY <= wY + 2 then track.Visible = false ; return end
        track.Visible = scroll.Visible
        local ratio  = math.clamp(wY / cY, 0.08, 1)
        local tH     = math.max(18, track.AbsoluteSize.Y * ratio)
        local maxS   = math.max(cY - wY, 1)
        local prog   = math.clamp(scroll.CanvasPosition.Y / maxS, 0, 1)
        local travel = math.max(track.AbsoluteSize.Y - tH, 0)
        thumb.Size     = UDim2.new(1, 0, 0, tH)
        thumb.Position = UDim2.new(0, 0, 0, travel * prog)
    end
    scroll:GetPropertyChangedSignal("CanvasPosition"):Connect(update)
    scroll:GetPropertyChangedSignal("CanvasSize"):Connect(update)
    scroll:GetPropertyChangedSignal("Visible"):Connect(update)
    scroll:GetPropertyChangedSignal("AbsoluteWindowSize"):Connect(update)
    parent:GetPropertyChangedSignal("AbsoluteSize"):Connect(update)
    task.defer(update)
    return track, thumb, update
end

local function makeDraggable(handle, target)
    local drag, ds, sp = false, nil, nil
    handle.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        drag = true ; ds = input.Position ; sp = target.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then drag = false end
        end)
    end)
    UserInputService.InputChanged:Connect(function(input)
        if not drag or input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local d = input.Position - ds
        target.Position = UDim2.new(sp.X.Scale, sp.X.Offset + d.X, sp.Y.Scale, sp.Y.Offset + d.Y)
    end)
end

