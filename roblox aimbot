        BorderSizePixel  = 0,
        Position         = UDim2.fromOffset(0, 350),
        Size             = UDim2.new(1,0,0,28),
        FontFace         = FontFaceValue,
        Text             = "›  Ready",
        TextColor3       = Theme.Muted,
        TextSize         = 11,
        TextXAlignment   = Enum.TextXAlignment.Left,
        Parent           = shell,
    })
    corner(output, 6)
    stroke(output, Theme.Outline)
    pad(output, 0,0,10,10)

    shell.Size = UDim2.new(1,0,0,390)

    local function setOut(msg, color)
        output.Text       = "›  "..msg
        output.TextColor3 = color or Theme.Muted
    end

    local function tryCopy(text)
        for _,fn in ipairs({rawget(getfenv(),"setclipboard"),rawget(getfenv(),"toclipboard")}) do
            if typeof(fn)=="function" then local ok=pcall(fn,text) ; if ok then return true end end
        end
        return false
    end

    -- editor logic (same as before)
    local suggItems={} ; local activeSug=nil ; local edFocused=false
    local lastText=editor.Text ; local internalUp=false ; local refreshQ=false
    local blockOpen={["then"]=true,["do"]=true,["function"]=true,["repeat"]=true}
    local autoPairs={["("]=")",["["]="]",["{"]="}",['"']='"',["\'"]="\'"  }

    local function rebuildNums(text)
        local lines,nums=1,{}
        for _ in text:gmatch("\n") do lines=lines+1 end
        for i=1,lines do nums[i]=tostring(i) end
        lineNums.Text=table.concat(nums,"\n")
    end
    local function syncCanvas()
        local h=math.max(editor.TextBounds.Y+8, edScroll.AbsoluteSize.Y-2)
        editor.Size=UDim2.new(1,-38,0,h) ; codeLayer.Size=UDim2.new(1,-38,0,h)
        lineNums.Size=UDim2.fromOffset(30,h) ; edScroll.CanvasSize=UDim2.fromOffset(0,h+4)
        curLine.Size=UDim2.new(1,-36,0,lineH)
    end
    local function clearSugs()
        for _,v in ipairs(suggItems) do v:Destroy() end
        suggItems={} ; activeSug=nil ; -- no suggestion box in compact mode
    end
    local function setEdState(txt,cur)
        internalUp=true ; editor.Text=txt ; editor.CursorPosition=cur
        internalUp=false ; lastText=txt
    end
    local function insertComp(comp, prefix)
        local cur=math.max(editor.CursorPosition,1) ; local txt=editor.Text
        local start=math.max(cur-#prefix-1,0)
        setEdState(txt:sub(1,start)..comp..txt:sub(cur,#txt), start+#comp+1)
    end
    local function insertAt(text, offset)
        local cur=math.max(editor.CursorPosition,1) ; local t=editor.Text
        setEdState(t:sub(1,cur-1)..text..t:sub(cur,#t), cur+(offset or #text))
    end

    local queueRefresh
    local updateCurLine

    local function refreshEd()
        placeholder.Visible = editor.Text==""
        codeLayer.Text = highlightLua(editor.Text=="" and " " or editor.Text)
        rebuildNums(editor.Text)
        syncCanvas()
    end
    queueRefresh = function()
        if refreshQ then return end ; refreshQ=true
        task.defer(function()
            refreshQ=false ; refreshEd()
            if updateCurLine then updateCurLine() end
        end)
    end
    updateCurLine = function()
        local cur=math.max(editor.CursorPosition,1)
        local before=editor.Text:sub(1,math.max(cur-1,0))
        local lineIdx=1
        for _ in before:gmatch("\n") do lineIdx=lineIdx+1 end
        local y=((lineIdx-1)*lineH) - edScroll.CanvasPosition.Y
        curLine.Position=UDim2.fromOffset(36,y)
        curLine.Visible=edFocused
    end

    local function applyAuto()
        if internalUp then return end
        local text=editor.Text ; local cur=editor.CursorPosition
        if cur<2 or #text<=#lastText then lastText=text ; return end
        local ch=text:sub(cur-2,cur-2)
        local updT,updC=text,cur
        if autoPairs[ch] then
            local close=autoPairs[ch] ; local right=text:sub(cur,cur)
            if right~=close then
                updT=text:sub(1,cur-1)..close..text:sub(cur,#text) ; updC=cur
            end
        elseif ch=="\n" then
            local beforeBreak=text:sub(1,cur-2):match("([^\n]*)\n?$") or ""
            local indent=beforeBreak:match("^(%s*)") or ""
            local lastWord=(beforeBreak:gsub("^%s+","")):match("([%a_]+)%s*$")
            if lastWord and blockOpen[lastWord] then indent=indent.."    " end
            updT=text:sub(1,cur-1)..indent..text:sub(cur,#text) ; updC=cur+#indent
        end
        if updT~=editor.Text or updC~=editor.CursorPosition then setEdState(updT,updC)
        else lastText=text end
    end

    editor:GetPropertyChangedSignal("Text"):Connect(function() applyAuto() ; queueRefresh() end)
    editor:GetPropertyChangedSignal("CursorPosition"):Connect(function() updateCurLine() end)
    edScroll:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
        local py=-edScroll.CanvasPosition.Y
        editor.Position=UDim2.fromOffset(38,py) ; codeLayer.Position=UDim2.fromOffset(38,py)
        lineNums.Position=UDim2.fromOffset(0,py) ; placeholder.Position=UDim2.fromOffset(38,py)
        updateCurLine()
    end)
    editor.Focused:Connect(function() edFocused=true ; queueRefresh() ; updateCurLine() end)
    editor.FocusLost:Connect(function() edFocused=false ; curLine.Visible=false end)

    UserInputService.InputBegan:Connect(function(input, gp)
        if not edFocused then return end
        if input.KeyCode==Enum.KeyCode.Tab then
            insertAt("    ",4) ; queueRefresh()
        end
    end)

    refreshEd() ; updateCurLine()

    runBtn.MouseButton1Click:Connect(function()
        local code=editor.Text
        if code=="" then setOut("Nothing to run") ; return end
        if typeof(loadstring)~="function" then setOut("loadstring unavailable", Theme.Error) ; return end
        local chunk,err=loadstring(code)
        if not chunk then setOut(err or "Compile error", Theme.Error) ; return end
        local ok,re=pcall(chunk)
        if ok then setOut("Executed successfully", Theme.Success)
        else setOut(re or "Runtime error", Theme.Error) end
    end)
    clearBtn.MouseButton1Click:Connect(function()
        editor.Text="" ; setOut("Cleared")
    end)
    copyBtn.MouseButton1Click:Connect(function()
        if editor.Text=="" then setOut("Nothing to copy") ; return end
        if tryCopy(editor.Text) then setOut("Copied", Theme.Success)
        else setOut("Clipboard unavailable", Theme.Error) end
    end)

    exTab:RegisterItem(shell, "executor script run clear copy", edFrame)
    return exTab, {
        Editor  = editor,
        Output  = output,
        SetText = function(t) editor.Text=t end,
        GetText = function() return editor.Text end,
    }
end

function Window:Notify(options)
    self.Library:Notify(options)
end

return Pulse
