function Animations:Open(win, transparency, useCurrentSize)
	local orig = (useCurrentSize and win.Size) or Setup.Size
	local big  = Multiply(orig, 1.07)
	local shad = win:FindFirstChildOfClass("UIStroke")

	win.Size              = big
	win.GroupTransparency = 1
	win.Visible           = true
	if shad then shad.Transparency = 1 end

	Tween(win, .2, { Size = orig, GroupTransparency = transparency or 0 })
	if shad then Tween(shad, .2, { Transparency = 0.55 }) end
end

function Animations:Close(win)
	local orig = win.Size
	local big  = Multiply(orig, 1.07)
	local shad = win:FindFirstChildOfClass("UIStroke")

	Tween(win, .16, { Size = big, GroupTransparency = 1 })
	if shad then Tween(shad, .16, { Transparency = 1 }) end
	task.wait(.18)
	win.Size    = orig
	win.Visible = false
end

-- [Fix 15] hover สี ถูกต้องผ่าน MouseEnter/Leave
function Animations:Component(comp, isTransparent)
	if isTransparent then
		Connect(comp.MouseEnter, function() Tween(comp, .12, { Transparency = .82 }) end)
		Connect(comp.MouseLeave, function() Tween(comp, .12, { Transparency = 1    }) end)
	else
		Connect(comp.MouseEnter, function() Tween(comp, .12, { BackgroundColor3 = Theme.Hover      }) end)
		Connect(comp.MouseLeave, function() Tween(comp, .12, { BackgroundColor3 = Theme.Component  }) end)
		Connect(comp.MouseButton1Down, function() Tween(comp, .08, { BackgroundColor3 = Theme.Interactables }) end)
		Connect(comp.MouseButton1Up,   function() Tween(comp, .12, { BackgroundColor3 = Theme.Hover          }) end)
	end
end

