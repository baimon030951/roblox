local function getInstanceSortPosition(instance)
    if instance:IsA("Model") then
        local cf = instance:GetPivot()
        return cf.Position
    end

    if instance:IsA("BasePart") then
        return instance.Position
    end

    local part = instance:FindFirstChildWhichIsA("BasePart", true)
    if part then
        return part.Position
    end

    return Vector3.zero
end

function getTargetTransform(target)
    if target:IsA("Model") then
        local cf, size = target:GetBoundingBox()
        return cf, size
    end

    if target:IsA("BasePart") then
        return target.CFrame, target.Size
    end

    local part = target:FindFirstChildWhichIsA("BasePart", true)
    if part then
        return part.CFrame, part.Size
    end

    if target:IsA("PVInstance") then
        return target:GetPivot(), Vector3.new(4, 4, 4)
    end

    return nil, nil
end

local function getFarmTargetsForJob(jobName)
    local targetFolder = getJobScriptFolder(jobName)
    if not targetFolder then
        return {}
    end

    local targets = {}
    for _, child in ipairs(targetFolder:GetChildren()) do
        local cf = getTargetTransform(child)
        if cf then
            table.insert(targets, child)
        end
    end

    table.sort(targets, function(a, b)
        local posA = getInstanceSortPosition(a)
        local posB = getInstanceSortPosition(b)

        if posA.X ~= posB.X then
            return posA.X < posB.X
        end
        if posA.Y ~= posB.Y then
            return posA.Y < posB.Y
        end
        if posA.Z ~= posB.Z then
            return posA.Z < posB.Z
        end

        return a:GetDebugId() < b:GetDebugId()
    end)

    return targets
end

