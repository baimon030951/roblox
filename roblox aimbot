        tab.Window = window
        tab.Name   = name
        tab.Items  = {}

        local button = create("TextButton", {
            BackgroundColor3 = Theme.Sidebar,
            BorderSizePixel  = 0,
            Size             = UDim2.new(1, 0, 0, 38),
            Text             = "",
            AutoButtonColor  = false,
