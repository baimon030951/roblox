            Description = state and "Anti-AFK enabled" or "Anti-AFK disabled",
            Type = state and "success" or "warning",
            Duration = 2
        })
    end
})

generalSection:AddToggle("Auto Eat Food", {
    Default = false,
    Callback = function(state)
        autoEatFoodEnabled = state

        if state and not autoEatFoodThread then
            autoEatFoodThread = task.spawn(function()
                while autoEatFoodEnabled do
                    local hungerValue = getStatusNumber("Hunger")
                    local brainValue = getStatusNumber("Brain")

                    if hungerValue and hungerValue < 25 then
                        pressKeyCode(Enum.KeyCode.Seven)
                        task.wait(0.2)
                    end

                    if brainValue and brainValue < 25 then
                        pressKeyCode(Enum.KeyCode.Eight)
                        task.wait(0.2)
                    end

                    task.wait(0.75)
                end

                autoEatFoodThread = nil
            end)
        end

        if not uiReady then
            return
        end

        window:Notify({
            Title = "General",
            Description = state and "Auto Eat Food enabled" or "Auto Eat Food disabled",
            Type = state and "success" or "warning",
            Duration = 2
        })
    end
})

generalSection:AddToggle("Noclip", {
    Default = false,
    Callback = function(state)
        noclipEnabled = state

        if noclipConnection then
            noclipConnection:Disconnect()
            noclipConnection = nil
        end

        if state then
            setCharacterNoclip(true)
            noclipConnection = RunService.Stepped:Connect(function()
                if noclipEnabled then
                    setCharacterNoclip(true)
                end
            end)
        else
            setCharacterNoclip(false)
        end

        if not uiReady then
            return
        end

        window:Notify({
            Title = "General",
            Description = state and "Noclip enabled" or "Noclip disabled",
            Type = state and "success" or "warning",
            Duration = 2
        })
    end
})

