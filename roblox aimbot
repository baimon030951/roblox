    local function update(p)
        p=math.clamp(p,0,1) ; val=math.floor(mn+(mx-mn)*p+0.5)
        valLbl.Text=tostring(val)
        fill.Size=UDim2.new(p,0,1,0) ; knob.Position=UDim2.new(p,0,0.5,0)
