        BackgroundColor3 = Theme.Background,
        BorderSizePixel  = 0,
        Parent           = self.ScreenGui,
    })
    corner(root, 16)
    stroke(root, Theme.Outline, 0.0)
    shadow(root, 20, 0.82)
    window.Root = root
    create("UISizeConstraint", { MinSize = window.MinSize, Parent = root })

    -- TOPBAR
    local topbar = create("Frame", {
        BackgroundColor3 = Theme.Topbar,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 0, 52),
        Parent           = root,
    })
    corner(topbar, 16)
    create("Frame", {    -- ปิดมุมล่าง
