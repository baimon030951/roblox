-- [[ WALLCHECK FUNCTION ]] --
local function IsVisible(part)
    if not _G.WallCheck then return true end
    
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("Head") then
        return false
    end
    
    local origin = Camera.CFrame.Position
    local direction = (part.Position - origin)
    
    -- Create raycast parameters
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    
    -- Filter out both characters completely
    local filterList = {LocalPlayer.Character, part.Parent}
    params.FilterDescendantsInstances = filterList
    
    -- Ignore transparent parts
    params.IgnoreWater = true
    
    -- Cast ray
    local result = workspace:Raycast(origin, direction, params)
    
    -- If ray hit something, target is behind wall
    if result then
        -- Double check - cast from target to camera
        local reverseParams = RaycastParams.new()
        reverseParams.FilterType = Enum.RaycastFilterType.Exclude
        reverseParams.FilterDescendantsInstances = filterList
        reverseParams.IgnoreWater = true
        
        local reverseResult = workspace:Raycast(part.Position, -direction, reverseParams)
        
        -- If both rays hit something, definitely behind wall
        if reverseResult then
            return false
        end
    end
    
    return result == nil
end

-- [[ AIMBOT LOGIC ]] --
local currentTarget = nil
local lastTargetTime = 0
local targetSwitchDelay = 0.5
local lastWallCheckFailed = false

RunService.RenderStepped:Connect(function()
    Circle.Radius = _G.FOV
    Circle.Position = UserInputService:GetMouseLocation()
    Circle.Visible = _G.AimEnabled
    
    -- Change circle color if wall check is blocking
    if _G.WallCheck and lastWallCheckFailed then
        Circle.Color = Color3.fromRGB(255, 165, 0) -- Orange when blocked
        WallCheckText.Visible = true
        WallCheckText.Position = Vector2.new(Circle.Position.X, Circle.Position.Y - Circle.Radius - 30)
        WallCheckText.Text = "⚠️ WALL BLOCKED"
    else
        Circle.Color = Color3.fromRGB(255, 0, 0) -- Red normal
        WallCheckText.Visible = false
    end

    -- Check if aim key is pressed
    local isAiming = false
    
    if _G.AimEnabled then
        if typeof(_G.AimKeybind) == "EnumItem" then
            if _G.AimKeybind.EnumType == Enum.KeyCode then
                isAiming = UserInputService:IsKeyDown(_G.AimKeybind)
            elseif _G.AimKeybind.EnumType == Enum.UserInputType then
                isAiming = UserInputService:IsMouseButtonPressed(_G.AimKeybind)
            end
        end
    end

    if isAiming then
        local closestTarget = nil
        local closestValue = math.huge
        local foundAnyTarget = false
        local allTargetsBlocked = true
        
        -- Find target based on priority mode
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(_G.AimPart) and v.Character:FindFirstChild("Humanoid") then
                local humanoid = v.Character.Humanoid
                
                if humanoid.Health > 0 then
                    local part = v.Character[_G.AimPart]
                    local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
                    
                    if onScreen then
                        local validTarget = false
                        local priorityValue = 0
                        
                        if _G.PriorityMode == "FOV" then
                            local screenDist = (Vector2.new(pos.X, pos.Y) - Circle.Position).Magnitude
                            if screenDist < _G.FOV then
                                foundAnyTarget = true
                                -- STRICT WALL CHECK HERE
                                if IsVisible(part) then
                                    validTarget = true
                                    priorityValue = screenDist
                                    allTargetsBlocked = false
                                end
                            end
                        else
                            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                                local myPos = LocalPlayer.Character.HumanoidRootPart.Position
                                local worldDist = (part.Position - myPos).Magnitude
                                
                                local screenDist = (Vector2.new(pos.X, pos.Y) - Circle.Position).Magnitude
                                if screenDist < _G.FOV then
                                    foundAnyTarget = true
                                    -- STRICT WALL CHECK HERE
                                    if IsVisible(part) then
                                        validTarget = true
                                        priorityValue = worldDist
                                        allTargetsBlocked = false
                                    end
                                end
                            end
                        end
                        
                        if validTarget and priorityValue < closestValue then
                            closestTarget = part
                            closestValue = priorityValue
                        end
                    end
                end
            end
        end
        
        -- Update wall check status
        if _G.WallCheck then
            lastWallCheckFailed = foundAnyTarget and allTargetsBlocked
        else
            lastWallCheckFailed = false
        end
        
        -- Target stickiness - but recheck wall every frame
        if closestTarget then
            -- Even if we have sticky target, recheck wall
            if currentTarget ~= closestTarget then
                local currentTime = tick()
                if currentTime - lastTargetTime > targetSwitchDelay then
                    currentTarget = closestTarget
                    lastTargetTime = currentTime
                end
            else
                -- Verify current target is still visible
                if _G.WallCheck and not IsVisible(currentTarget) then
                    currentTarget = nil -- Lose lock if target goes behind wall
                else
                    currentTarget = closestTarget
                end
            end
        else
            currentTarget = nil
        end
        
        -- Smooth aiming - ONLY if target passes wall check
        if currentTarget and currentTarget.Parent then
            -- Final wall check before aiming
            if _G.WallCheck and not IsVisible(currentTarget) then
                currentTarget = nil
                return
            end
            
            local targetPos = currentTarget.Position
            
            -- Prediction
            local humanoidRootPart = currentTarget.Parent:FindFirstChild("HumanoidRootPart")
            if humanoidRootPart and humanoidRootPart:IsA("BasePart") then
                local velocity = humanoidRootPart.AssemblyLinearVelocity
                local distance = (humanoidRootPart.Position - Camera.CFrame.Position).Magnitude
                local predictionTime = distance / 1000
                local prediction = velocity * predictionTime
                targetPos = targetPos + prediction
            end
            
            local targetCFrame = CFrame.new(Camera.CFrame.Position, targetPos)
            
            local smoothFactor = 1 / _G.Smoothness
            smoothFactor = math.clamp(smoothFactor, 0.01, 1)
            
            Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, smoothFactor)
        end
    else
        currentTarget = nil
        lastWallCheckFailed = false
    end
end)

