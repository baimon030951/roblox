local function FindAvailableGrape()
    local folder = workspace:FindFirstChild("JOB") and workspace.JOB:FindFirstChild("JOB") and workspace.JOB.JOB:FindFirstChild("SCRIPT") and workspace.JOB.JOB.SCRIPT:FindFirstChild("Grape")
    if not folder then return nil, nil end
    for _, g in pairs(folder:GetChildren()) do
        if not g:IsA("BasePart") then continue end
        local key = GetPosKey(g.Position)
        if not Config.Farm.Grape.Visited[key] then return g, key end
    end
    return nil, nil
end

local function StartGrapeFarm()
    task.spawn(function()
        while Config.Farm.Grape.Enabled do
            local truck = GetTruckForFarming()
            if truck then
                pcall(function()
                    game.ReplicatedStorage.Remote.data:FireServer("post", "Grape", Config.Farm.Settings.CollectAmount, truck)
                end)
            else
                Notify("ไม่พบรถ", "ส่งองุ่นไม่ได้", "alert-triangle")
            end
            task.wait(Config.Farm.Settings.TeleportDelay)
        end
    end)
    task.spawn(function()
        while Config.Farm.Grape.Enabled do
            local folder = workspace:FindFirstChild("JOB") and workspace.JOB:FindFirstChild("JOB") and workspace.JOB.JOB:FindFirstChild("SCRIPT") and workspace.JOB.JOB.SCRIPT:FindFirstChild("Grape")
            if not folder then task.wait(1) continue end
            local items = {}
            for _, g in pairs(folder:GetChildren()) do
                if g:IsA("BasePart") then table.insert(items, g) end
            end
            if #items == 0 then task.wait(1) continue end

            if Config.Farm.Settings.FarmMode == 2 then
                -- โหมด 2: index pointer เดินหน้าทีละตัว ไม่ซ้ำจนครบแล้ววนใหม่
                if Config.Farm.Grape.Index > #items then
                    Config.Farm.Grape.Index = 1
                    Config.Farm.Grape.TeleportCounter = 0
                    task.wait(0.5)
                    continue
                end
                local g = items[Config.Farm.Grape.Index]
                Config.Farm.Grape.TeleportCounter += 1
                if TeleportAndJump(g.CFrame) then
                    if Config.Farm.Grape.TeleportCounter >= Config.Farm.Settings.TeleportCount then
                        Config.Farm.Grape.Index += 1
                        Config.Farm.Grape.TeleportCounter = 0
                    end
                    task.wait(Config.Farm.Settings.TeleportDelay)
                end
            else
                -- โหมด 1: แบบเดิม
                if CountVisited(Config.Farm.Grape.Visited) >= #items then
                    Config.Farm.Grape.Visited = {}
                    task.wait(0.5)
                end
                local g, key = FindAvailableGrape()
                if g then
                    Config.Farm.Grape.TeleportCounter += 1
                    if TeleportAndJump(g.CFrame) then
                        if Config.Farm.Grape.TeleportCounter >= Config.Farm.Settings.TeleportCount then
                            Config.Farm.Grape.Visited[key] = true
                            Config.Farm.Grape.TeleportCounter = 0
                        end
                        task.wait(Config.Farm.Settings.TeleportDelay)
                    end
                else
                    Config.Farm.Grape.Visited = {}
                    Config.Farm.Grape.TeleportCounter = 0
                    task.wait(0.5)
                end
            end
        end
    end)
end

