	function Options:AddToggle(cfg)
		local toggle     = Clone(Components["Toggle"])
		local title, desc = Options:GetLabels(toggle)
		local on         = toggle["Value"]
		local track      = toggle["Main"]
		local circle     = track["Circle"]

		local function Set(val)
			on.Value = val
			if val then
				Tween(track,  .18, { BackgroundColor3 = Theme.Accent    })
				Tween(circle, .18, { BackgroundColor3 = Theme.CircleOn,  Position = UDim2.new(1, -18, 0.5, 0) })
			else
				Tween(track,  .18, { BackgroundColor3 = Theme.ToggleOff })
				Tween(circle, .18, { BackgroundColor3 = Theme.CircleOff, Position = UDim2.new(0, 4,   0.5, 0) })
			end
		end

		Connect(toggle.MouseButton1Click, function()
			Set(not on.Value)
			cfg.Callback(on.Value)
		end)

		Animations:Component(toggle)
		Set(cfg.Default or false)
		SetProperty(title,  { Text = cfg.Title,       TextColor3 = Theme.Title,       Font = Enum.Font.GothamBold, TextSize = Setup.FontSize.ComponentTitle })
		SetProperty(desc,   { Text = cfg.Description, TextColor3 = Theme.Description, Font = Enum.Font.Gotham,     TextSize = Setup.FontSize.Description })
		SetProperty(toggle, { Name = cfg.Title, Parent = cfg.Tab, Visible = true, BackgroundColor3 = Theme.Component })

		return { Set = Set, GetValue = function() return on.Value end }
	end

	function Options:AddKeybind(cfg)
		local kb         = Clone(Components["Keybind"])
		local title, desc = Options:GetLabels(kb)
		local bind       = kb["Main"].Options
		local mBtns      = { Enum.UserInputType.MouseButton1, Enum.UserInputType.MouseButton2, Enum.UserInputType.MouseButton3 }

		Connect(kb.MouseButton1Click, function()
			local done = false
			local conn
			SetProperty(bind, { Text = "...", TextColor3 = Theme.Accent })

			-- [Fix 5]
			conn = Connect(Services.Input.InputBegan, function(key, focused)
				if done or focused then return end
				done = true
				conn:Disconnect()

				local it = key.UserInputType
				if table.find(mBtns, it) then
					cfg.Callback(key)
					bind.Text = tostring(it):gsub("Enum%.UserInputType%.MouseButton", "MB")
				elseif it == Enum.UserInputType.Keyboard then
					cfg.Callback(key)
					bind.Text = tostring(key.KeyCode):gsub("Enum%.KeyCode%.", "")
				end
				bind.TextColor3 = Theme.Title
			end)
		end)

		Animations:Component(kb)
		SetProperty(title, { Text = cfg.Title,       TextColor3 = Theme.Title,       Font = Enum.Font.GothamBold,     TextSize = Setup.FontSize.ComponentTitle })
		SetProperty(desc,  { Text = cfg.Description, TextColor3 = Theme.Description, Font = Enum.Font.Gotham,          TextSize = Setup.FontSize.Description })
		SetProperty(bind,  { TextColor3 = Theme.Tab, Font = Enum.Font.GothamSemibold, TextSize = Setup.FontSize.Badge })
		SetProperty(kb,    { Name = cfg.Title, Parent = cfg.Tab, Visible = true, BackgroundColor3 = Theme.Component })
	end

	function Options:AddDropdown(cfg)
		local dd         = Clone(Components["Dropdown"])
		local title, desc = Options:GetLabels(dd)
		local selText    = dd["Main"].Options

		Connect(dd.MouseButton1Click, function()
			local ex      = Clone(Examples["DropdownExample"])
			local closeBtns = ex["Top"]["Buttons"]

			Tween(BG, .18, { BackgroundTransparency = 0.5 })
			SetProperty(ex, { Parent = Window, BackgroundColor3 = Theme.Secondary })
			Animations:Open(ex, 0, true)

			local function closeDD()
				Tween(BG, .18, { BackgroundTransparency = 1 })
				Animations:Close(ex)
				task.delay(.22, function() pcall(Destroy, ex) end)
			end

			for _, btn in next, closeBtns:GetChildren() do
				if btn:IsA("TextButton") then
					Animations:Component(btn, true)
					Connect(btn.MouseButton1Click, closeDD)
				end
			end

			-- [Fix 4]
			local selectedBtn = nil

			for label, value in next, cfg.Options do
				local optBtn           = Clone(Examples["DropdownButtonExample"])
				local optTitle, optDesc = Options:GetLabels(optBtn)

				Animations:Component(optBtn)
				SetProperty(optTitle, { Text = label, TextColor3 = Theme.Title, Font = Enum.Font.GothamSemibold, TextSize = Setup.FontSize.ComponentTitle })
				SetProperty(optBtn,   { Parent = ex.ScrollingFrame, Visible = true, BackgroundColor3 = Theme.Component })
				if optDesc then Destroy(optDesc) end

				Connect(optBtn.MouseButton1Click, function()
					if selectedBtn and selectedBtn ~= optBtn then
						Tween(selectedBtn, .12, { BackgroundColor3 = Theme.Component })
					end
					selectedBtn = optBtn
					Tween(optBtn, .12, { BackgroundColor3 = Theme.Interactables })

					cfg.Callback(value)
					selText.Text      = label
					selText.TextColor3 = Theme.Title

					task.delay(.07, closeDD)
				end)
			end
		end)

		Animations:Component(dd)
		SetProperty(title,   { Text = cfg.Title,       TextColor3 = Theme.Title,       Font = Enum.Font.GothamBold,     TextSize = Setup.FontSize.ComponentTitle })
		SetProperty(desc,    { Text = cfg.Description, TextColor3 = Theme.Description, Font = Enum.Font.Gotham,          TextSize = Setup.FontSize.Description })
		SetProperty(selText, { TextColor3 = Theme.Tab, Font = Enum.Font.GothamSemibold, TextSize = Setup.FontSize.Badge })
		SetProperty(dd,      { Name = cfg.Title, Parent = cfg.Tab, Visible = true, BackgroundColor3 = Theme.Component })
	end

	function Options:AddSlider(cfg)
		local slider     = Clone(Components["Slider"])
		local title, desc = Options:GetLabels(slider)
		local main       = slider["Slider"]
		local amount     = main["Main"].Input
		local slide      = main["Slide"]
		local fire       = slide["Fire"]
		local fill       = slide["Highlight"]

		-- [Fix 6]
		local minVal = cfg.MinValue or 0
		local maxVal = cfg.MaxValue or 100
		local value  = math.clamp(cfg.Default or minVal, minVal, maxVal)
		local active = false
		local runConn

		local function Round(n)
			if cfg.AllowDecimals then
				local p = 10 ^ (cfg.DecimalAmount or 2)
				return math.floor(n * p + 0.5) / p
			end
			return math.round(n)
		end

		-- [Fix 7] render only, no callback on init
		local function Render(v)
			value       = Round(math.clamp(v, minVal, maxVal))
			amount.Text = value
			fill.Size   = UDim2.fromScale((value - minVal) / (maxVal - minVal), 1)
			fill.BackgroundColor3 = Theme.SliderFill
		end

		local function Update()
			local scale = (Player.Mouse.X - slide.AbsolutePosition.X) / slide.AbsoluteSize.X
			local v     = minVal + math.clamp(scale, 0, 1) * (maxVal - minVal)
			Render(v)
			cfg.Callback(value)
		end

		Render(value)  -- init display, no callback

		Connect(amount.FocusLost, function()
			local v = tonumber(amount.Text) or value
			Render(v)
			cfg.Callback(value)
		end)

		-- [Fix 12] RenderStepped แทน loop
		Connect(fire.MouseButton1Down, function()
			active = true
			runConn = Connect(Services.Run.RenderStepped, function()
				if active then Update() end
			end)
		end)
		Connect(Services.Input.InputEnded, function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 or
			   inp.UserInputType == Enum.UserInputType.Touch then
				active = false
				if runConn then runConn:Disconnect(); runConn = nil end
			end
		end)

		Animations:Component(slider)
		SetProperty(title,  { Text = cfg.Title,       TextColor3 = Theme.Title,       Font = Enum.Font.GothamBold,     TextSize = Setup.FontSize.ComponentTitle })
		SetProperty(desc,   { Text = cfg.Description, TextColor3 = Theme.Description, Font = Enum.Font.Gotham,          TextSize = Setup.FontSize.Description })
		SetProperty(amount, { TextColor3 = Theme.Title, Font = Enum.Font.GothamSemibold, TextSize = Setup.FontSize.Badge })
		SetProperty(slider, { Name = cfg.Title, Parent = cfg.Tab, Visible = true, BackgroundColor3 = Theme.Component })
	end

