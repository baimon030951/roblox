-- SYNTAX HIGHLIGHT (blue palette)
-- ============================================================
local LuaKeywords = {
    ["and"]=true,["break"]=true,["do"]=true,["else"]=true,["elseif"]=true,
    ["end"]=true,["false"]=true,["for"]=true,["function"]=true,["if"]=true,
    ["in"]=true,["local"]=true,["nil"]=true,["not"]=true,["or"]=true,
    ["repeat"]=true,["return"]=true,["then"]=true,["true"]=true,["until"]=true,
    ["while"]=true,
}
local SyntaxColors = {
    keyword = "#007aff",
    string  = "#30a852",
    number  = "#e07c00",
    comment = "#aaaaaa",
    func    = "#0055cc",
    roblox  = "#0055cc",
    normal  = "#1c1c20",
}
local RobloxIds = {
    ["self"]=true,["Enum"]=true,["Instance"]=true,["game"]=true,
    ["workspace"]=true,["script"]=true,["math"]=true,["table"]=true,
    ["string"]=true,["Color3"]=true,["Vector2"]=true,["Vector3"]=true,
    ["UDim2"]=true,["CFrame"]=true,["TweenService"]=true,["Players"]=true,
    ["Workspace"]=true,["ReplicatedStorage"]=true,["RunService"]=true,
    ["UserInputService"]=true,["TextService"]=true,["HttpService"]=true,
}
local function richEsc(t)
    return (t:gsub("&","&amp;"):gsub("<","&lt;"):gsub(">","&gt;"))
end
local function col(text, color)
    return ('<font color="%s">%s</font>'):format(color, richEsc(text))
end
local function highlightLua(code)
    local out, i, len = {}, 1, #code
    while i <= len do
        local two = code:sub(i,i+1) ; local ch = code:sub(i,i)
        if two == "--" then
            local stop = code:find("\n",i,true) or (len+1)
            table.insert(out, col(code:sub(i,stop-1), SyntaxColors.comment))
            if stop <= len then table.insert(out,"\n") end
            i = stop+1
        elseif ch=='"' or ch=="'" then
            local q,j = ch, i+1
            while j<=len do
                local c=code:sub(j,j)
                if c=="\\" then j=j+2 elseif c==q then j=j+1;break else j=j+1 end
            end
            table.insert(out, col(code:sub(i,math.min(j-1,len)), SyntaxColors.string))
            i=j
        elseif ch:match("[%a_]") then
            local j=i
            while j<=len and code:sub(j,j):match("[%w_]") do j=j+1 end
            local word=code:sub(i,j-1)
            local nxt=code:match("^%s*(.)",j) or ""
            local consumed=false
            if word=="Instance" and code:sub(j,j+3)==".new" then
                table.insert(out, col("Instance.new", SyntaxColors.func))
                i=j+4 ; consumed=true
            elseif LuaKeywords[word] then
                table.insert(out, col(word, SyntaxColors.keyword))
            elseif RobloxIds[word] then
                table.insert(out, col(word, SyntaxColors.roblox))
            elseif nxt=="(" then
                table.insert(out, col(word, SyntaxColors.func))
            else
                table.insert(out, col(word, SyntaxColors.normal))
            end
            if not consumed then i=j end
        elseif ch:match("%d") then
            local j=i
            while j<=len and code:sub(j,j):match("[%d%.]") do j=j+1 end
            table.insert(out, col(code:sub(i,j-1), SyntaxColors.number))
            i=j
        else
            table.insert(out, richEsc(ch)) ; i=i+1
        end
    end
    return table.concat(out)
end

-- autocomplete
local CompletionSets = {
    game    = {"GetService","Players","Workspace","ReplicatedStorage","Lighting"},
    enum    = {"KeyCode","UserInputType","EasingStyle","EasingDirection","Font"},
    instance= {"new"},
    globals = {"local","function","if","then","end","for","while","return","print","game","Enum","Instance"},
}
local function getCompletions(src)
    local function f(set, prefix)
        local r={}
        for _,v in ipairs(set) do
            if v:lower():find(prefix:lower(),1,true)==1 then r[#r+1]=v end
        end
        return r
    end
    local gp=src:match("game%.([%w_]*)$") ; if gp then return f(CompletionSets.game,gp),"game",gp end
    local ep=src:match("Enum%.([%w_]*)$") ; if ep then return f(CompletionSets.enum,ep),"enum",ep end
    local ip=src:match("Instance%.([%w_]*)$") ; if ip then return f(CompletionSets.instance,ip),"instance",ip end
    local wp=src:match("([%a_][%w_]*)$") ; if wp then return f(CompletionSets.globals,wp),"word",wp end
    return {},"",""
end

