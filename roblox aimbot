local function refreshBaccaratOverlay()
    local state = ensureBaccaratOverlay()
    local _, remote = getBaccaratSource()
    if not remote then
        state.RecentLabel.Text = "-"
        state.Prediction.Text = "Recommend: WAIT"
        state.BankerLabel.Text = "B 0%"
        state.PlayerLabel.Text = "P 0%"
        state.TieLabel.Text = "T 0%"
        state.PercentLabel.Text = "B: 0% | P: 0% | T: 0%"
        state.StreakLabel.Text = "Streak: -"
        state.Status.Text = "Status: Waiting for baccarat table..."
        return
    end

    local history = decodeBaccaratHistory(remote)
    local latest = {}
    local startIndex = math.max(1, #history - 9)
    for i = startIndex, #history do
        table.insert(latest, formatBaccaratResult(history[i]))
    end

    local prediction = predictBaccarat(history)
    state.RecentLabel.Text = #latest > 0 and table.concat(latest, "  ") or "-"
    state.Prediction.Text = "Recommend: " .. prediction.Recommendation
    state.BankerLabel.Text = string.format("B %d%%", prediction.BankerPercent)
    state.PlayerLabel.Text = string.format("P %d%%", prediction.PlayerPercent)
    state.TieLabel.Text = string.format("T %d%%", prediction.TiePercent)
    state.PercentLabel.Text = string.format("B: %d%% | P: %d%% | T: %d%%", prediction.BankerPercent,
        prediction.PlayerPercent, prediction.TiePercent)

    local streakText = "-"
    if prediction.StreakType == "bankerwin" then
        streakText = string.format("BANKER x%d", prediction.StreakCount)
    elseif prediction.StreakType == "playerwin" then
        streakText = string.format("PLAYER x%d", prediction.StreakCount)
    elseif prediction.StreakType == "tie" then
        streakText = string.format("TIE x%d", prediction.StreakCount)
    end
    state.StreakLabel.Text = "Streak: " .. streakText

    local stepText = remote.Parent:GetAttribute("ShowStep") or "Unknown"
    state.Status.Text = "Status: " .. tostring(stepText)
end

local function getCarPrimaryPart(car)
    if car:IsA("Model") then
        return car.PrimaryPart or car:FindFirstChildWhichIsA("BasePart", true)
    end

    if car:IsA("BasePart") then
        return car
    end

    return car:FindFirstChildWhichIsA("BasePart", true)
end

local function getNearbyCars(maxDistance)
    local keepCarFolder = workspace:FindFirstChild("KeepCar")
    local rootPart = getRootPart()
    if not keepCarFolder or not rootPart then
        return {}
    end

    local results = {}
    for _, car in ipairs(keepCarFolder:GetChildren()) do
        local primaryPart = getCarPrimaryPart(car)
        if primaryPart then
            local distance = (primaryPart.Position - rootPart.Position).Magnitude
            if distance >= 0 and distance <= maxDistance then
                table.insert(results, {
                    instance = car,
                    distance = distance
                })
            end
        end
    end

    table.sort(results, function(a, b)
        return a.distance < b.distance
    end)

    return results
end

local function getNearestKeepCar()
    local keepCarFolder = workspace:FindFirstChild("KeepCar")
    local rootPart = getRootPart()
    if not keepCarFolder or not rootPart then
        return nil
    end

    local nearestCar = nil
    local nearestDistance = math.huge
    for _, car in ipairs(keepCarFolder:GetChildren()) do
        local primaryPart = getCarPrimaryPart(car)
        if primaryPart then
            local distance = (primaryPart.Position - rootPart.Position).Magnitude
            if distance < nearestDistance then
                nearestDistance = distance
                nearestCar = car
            end
        end
    end

    return nearestCar
end

