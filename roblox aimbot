function Library:CreateWindow(Settings)
	local Window  = Clone(Screen:WaitForChild("Main"))
	local Sidebar = Window:FindFirstChild("Sidebar")
	local Holder  = Window:FindFirstChild("Main")
	local BG      = Window:FindFirstChild("BackgroundShadow")
	local TabList = Sidebar:FindFirstChild("Tab")

	local Options     = {}
	local Examples    = {}
	local Opened      = true
	local Minimized   = false
	local Maximized   = false
	local BlurEnabled = false
	local FirstTab    = true   -- [Fix 8]

	for _, ex in next, Window:GetDescendants() do
		if ex.Name:find("Example") and not Examples[ex.Name] then
			Examples[ex.Name] = ex
		end
	end

	-- Apply initial theme
	if Settings.Theme and Themes[Settings.Theme] then
		Theme = Themes[Settings.Theme]
	end

	Setup.Transparency = Settings.Transparency or 0
	Setup.Size         = Settings.Size or UDim2.new(0, 680, 0, 460)
	Setup.ThemeMode    = Settings.Theme or "Dark"

	if Settings.FontSize then
		for k, v in next, Settings.FontSize do Setup.FontSize[k] = v end
	end

	Drag(Window)
	Resizeable(Window, Vector2.new(480, 300), Vector2.new(9e9, 9e9))

	if Settings.Blurring then
		Blurs[Settings.Title] = Blur.new(Window, 5)
		BlurEnabled = true
	end
	if Settings.MinimizeKeybind then
		Setup.Keybind = Settings.MinimizeKeybind
	end

	-- ── Font Apply ──────────────────────────
	local function ApplyFontSizes(root)
		for _, obj in next, root:GetDescendants() do
			if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
				local n  = obj.Name
				local pn = obj.Parent and obj.Parent.Name or ""

				if n == "Title" then
					obj.Font = Enum.Font.GothamBold
					obj.TextSize = Setup.FontSize.ComponentTitle
				elseif n == "Section" then
					obj.Font = Enum.Font.GothamSemibold
					obj.TextSize = Setup.FontSize.SectionLabel
				elseif n == "Description" then
					obj.Font = Enum.Font.Gotham
					obj.TextSize = Setup.FontSize.Description
				elseif pn == "Tab" or n == "TextLabel" then
					obj.Font = Enum.Font.GothamSemibold
					obj.TextSize = Setup.FontSize.Tab
				elseif n == "Options" or n == "Input" or n == "Amount" then
					obj.Font = Enum.Font.GothamSemibold
					obj.TextSize = Setup.FontSize.Badge
				else
					obj.Font = Enum.Font.GothamSemibold
					obj.TextSize = Setup.FontSize.ComponentTitle
				end
			end
		end
	end

	-- ── Theme Apply (Fix 10: Window scope only) ──
	local function ApplyTheme()
		Window.BackgroundColor3 = Theme.Primary
		Holder.BackgroundColor3 = Theme.Secondary
		if Sidebar then Sidebar.BackgroundColor3 = Theme.SidebarBG end

		local winStroke = Window:FindFirstChildOfClass("UIStroke")
		if winStroke then winStroke.Color = Theme.Shadow end

		for _, d in next, Window:GetDescendants() do
			local n  = d.Name
			local cn = d.ClassName

			-- text colours
			if (cn == "TextLabel" or cn == "TextButton") then
				if     n == "Title"       then d.TextColor3 = Theme.Title
				elseif n == "Description" then d.TextColor3 = Theme.Description
				elseif n == "Section"     then d.TextColor3 = Theme.Section
				elseif n == "Options"     then d.TextColor3 = Theme.Tab
				elseif n == "TextLabel" and d.Parent and d.Parent:FindFirstChild("List") then
					d.TextColor3 = Theme.Tab
				end
			end

			-- component card bg
			if cn == "TextButton" and d:FindFirstChild("Labels") then
				d.BackgroundColor3 = Theme.Component
			end

			-- frames
			if cn == "Frame" then
				if n == "Main" then
					if d.Parent == Window then
						d.BackgroundColor3 = Theme.Secondary
					elseif d.Parent and d.Parent:FindFirstChild("Value") then
						local tog  = d.Parent.Value
						local circ = d:FindFirstChild("Circle")
						if tog and tog.Value then
							d.BackgroundColor3 = Theme.Accent
							if circ then circ.BackgroundColor3 = Theme.CircleOn end
						else
							d.BackgroundColor3 = Theme.ToggleOff
							if circ then circ.BackgroundColor3 = Theme.CircleOff end
						end
					else
						d.BackgroundColor3 = Theme.Interactables
					end
				elseif n == "Amount" or n == "Slide" then
					d.BackgroundColor3 = Theme.Interactables
				elseif n == "Underline" then
					d.BackgroundColor3 = Theme.Outline
				elseif n == "Highlight" then
					d.BackgroundColor3 = Theme.SliderFill
				end
			end

			-- outline stroke
			if cn == "UIStroke" and n == "Outline" then
				d.Color = Theme.Outline
			end

			-- icons
			if cn == "ImageLabel" and d.Image ~= "rbxassetid://6644618143" then
				d.ImageColor3 = Theme.Icon
			end

			-- scrollbar
			if cn == "ScrollingFrame" then
				d.ScrollBarImageColor3 = Theme.Interactables
			end

			-- notifications
			if cn == "CanvasGroup" and n == "Notification" then
				d.BackgroundColor3 = Theme.Component
				local s = d:FindFirstChildOfClass("UIStroke")
				if s then s.Color = Theme.Outline end
			end
		end
	end

	-- ── Blur helper (Fix 3) ──────────────────
	local function SafeBlur(show)
		if not BlurEnabled then return end
		local b = Blurs[Settings.Title]
		if not b or not b.root then return end
		b.root.Parent = show and workspace.CurrentCamera or nil
	end

	-- ── Toggle Window ────────────────────────
	local function ToggleWindow()
		if Opened then
			SafeBlur(false)
			Opened = false
			Animations:Close(Window)
		else
			Animations:Open(Window, Setup.Transparency)
			Opened = true
			SafeBlur(true)
		end
	end

	-- ── 3-dot Buttons ───────────────────────
	for _, btn in next, Sidebar.Top.Buttons:GetChildren() do
		if btn:IsA("TextButton") then
			local name = btn.Name
			Animations:Component(btn, true)

			Connect(btn.MouseButton1Click, function()

				if name == "Close" or name == "Red" then
					-- [Fix 3]
					local b = Blurs[Settings.Title]
					if b and b.root then b.root:Destroy() end
					Destroy(Window)

				elseif name == "Minimize" or name == "Orange" then
					if not Minimized then
						Minimized = true
						if Holder then
							-- [Fix 9] Holder visible→invisible with tween
							Tween(Holder, .16, { Size = UDim2.new(0, 0, 0, 0) })
							task.delay(.18, function() Holder.Visible = false end)
						end
						Tween(Window, .16, {
							Size = UDim2.new(
								Window.Size.X.Scale, Window.Size.X.Offset,
								0, Sidebar.Top and Sidebar.Top.AbsoluteSize.Y or 36
							)
						})
					else
						Minimized = false
						if Holder then
							Holder.Visible = true
							Holder.Size    = UDim2.new(1, 0, 1, 0) -- restore immediately
						end
						Tween(Window, .18, { Size = Setup.Size })
					end

				elseif name == "Maximize" or name == "Green" then
					if Maximized then
						Maximized = false
						Tween(Window, .18, { Size = Setup.Size, Position = UDim2.fromScale(0.5, 0.5) })
					else
						Maximized = true
						Tween(Window, .18, { Size = UDim2.fromScale(1, 1), Position = UDim2.fromScale(0.5, 0.5) })
					end
				end
			end)
		end
	end

	Connect(Services.Input.InputBegan, function(inp, focused)
		if (inp == Setup.Keybind or inp.KeyCode == Setup.Keybind) and not focused then
			ToggleWindow()
		end
	end)

	-- ═══════════════════════════════════════
	--  Tab System
	-- ═══════════════════════════════════════
	function Options:SetTab(name)
		for _, btn in next, TabList:GetChildren() do
			if btn:IsA("TextButton") then
				local same    = btn.Name == name
				local isOpen  = btn.Value
				local padding = btn:FindFirstChildOfClass("UIPadding")
				local lbl     = btn:FindFirstChild("TextLabel")

				if same and not isOpen.Value then
					isOpen.Value = true
					if padding then Tween(padding, .2, { PaddingLeft = UDim.new(0, 20) }) end
					Tween(btn, .2, { BackgroundTransparency = 0.87, Size = UDim2.new(1, -10, 0, 32) })
					if lbl then Tween(lbl, .2, { TextColor3 = Theme.TabActive }) end

				elseif not same and isOpen.Value then
					isOpen.Value = false
					if padding then Tween(padding, .2, { PaddingLeft = UDim.new(0, 12) }) end
					Tween(btn, .2, { BackgroundTransparency = 1, Size = UDim2.new(1, -36, 0, 32) })
					if lbl then Tween(lbl, .2, { TextColor3 = Theme.Tab }) end
				end
			end
		end

		for _, main in next, Holder:GetChildren() do
			if main:IsA("CanvasGroup") then
				local same   = main.Name == name
				local isOpen = main.Value
				local scroll = main:FindFirstChild("ScrollingFrame")

				if same and not isOpen.Value then
					isOpen.Value = true
					main.Visible = true
					Tween(main, .22, { GroupTransparency = 0 })
					if scroll and scroll:FindFirstChild("UIPadding") then
						Tween(scroll.UIPadding, .22, { PaddingTop = UDim.new(0, 8) })
					end
				elseif not same and isOpen.Value then
					isOpen.Value = false
					Tween(main, .14, { GroupTransparency = 1 })
					if scroll and scroll:FindFirstChild("UIPadding") then
						Tween(scroll.UIPadding, .14, { PaddingTop = UDim.new(0, 20) })
					end
					task.delay(.16, function() main.Visible = false end)
				end
			end
		end
	end

