-- AddButton
function Section:AddButton(options)
    options = options or {}
    local hasSub = options.SubText and options.SubText~=""
    local btn = create("TextButton", {
        BackgroundColor3 = Theme.Background,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1,0,0,hasSub and 50 or 36),
        Text             = "",
        AutoButtonColor  = false,
        Parent           = self.Holder,
    })
    corner(btn, 7)
    stroke(btn, Theme.Outline)
    ripple(btn)

    local titleLbl = create("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.fromOffset(10, hasSub and 5 or 0),
        Size                   = UDim2.new(1,-20,0,16),
        FontFace               = FontFaceValue,
        Text                   = options.Text or "Button",
        TextColor3             = Theme.Text,
        TextSize               = 13,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Parent                 = btn,
    })
    local subLbl
    if hasSub then
        subLbl = create("TextLabel", {
            BackgroundTransparency = 1,
            Position               = UDim2.fromOffset(10, 22),
            Size                   = UDim2.new(1,-20,0,14),
            FontFace               = FontFaceValue,
            Text                   = options.SubText,
            TextColor3             = Theme.Muted,
            TextSize               = 10,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Parent                 = btn,
        })
    end

    -- chevron right
    create("TextLabel", {
        BackgroundTransparency = 1,
        AnchorPoint            = Vector2.new(1,0.5),
        Position               = UDim2.new(1,-10,0.5,0),
        Size                   = UDim2.fromOffset(10,10),
        FontFace               = FontFaceValue,
        Text                   = "›",
        TextColor3             = Theme.Muted,
        TextSize               = 16,
        Parent                 = btn,
    })

    btn.MouseEnter:Connect(function() tween(btn, SnapTween, {BackgroundColor3=Theme.Surface2}) end)
    btn.MouseLeave:Connect(function() tween(btn, SnapTween, {BackgroundColor3=Theme.Background}) end)
    btn.MouseButton1Click:Connect(function() safeCall(options.Callback) end)

    self.Tab:RegisterItem(btn, (options.Text or "button").." "..(options.SubText or ""))
    self.Tab.Window.Library:_bindTooltip(btn, options.Tooltip)
    return {
        Instance   = btn,
        SetText    = function(_,t) titleLbl.Text=t end,
        SetSubText = function(_,t)
            local show = t and t~=""
            if show and not subLbl then
                subLbl = create("TextLabel",{
                    BackgroundTransparency=1,Position=UDim2.fromOffset(10,22),
                    Size=UDim2.new(1,-20,0,14),FontFace=FontFaceValue,
                    Text=t,TextColor3=Theme.Muted,TextSize=10,
                    TextXAlignment=Enum.TextXAlignment.Left,Parent=btn,
                })
            elseif subLbl then subLbl.Text=t or "" ; subLbl.Visible=show end
            btn.Size=UDim2.new(1,0,0,show and 50 or 36)
            titleLbl.Position=UDim2.fromOffset(10, show and 5 or 0)
        end,
    }
end

-- AddButtonGroup
function Section:AddButtonGroup(options)
    options = options or {}
    local expanded = options.DefaultExpanded or false

    local group = create("Frame", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1,0,0,36),
        ClipsDescendants       = true,
        Parent                 = self.Holder,
    })
    local mainBtn = create("TextButton", {
        BackgroundColor3 = Theme.Background,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1,0,0,36),
        Text             = "",
        AutoButtonColor  = false,
        Parent           = group,
    })
    corner(mainBtn, 7)
    stroke(mainBtn, Theme.Outline)
    ripple(mainBtn)

    create("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.fromOffset(10,0),
        Size                   = UDim2.new(1,-40,1,0),
        FontFace               = FontFaceValue,
        Text                   = options.Text or "Group",
        TextColor3             = Theme.Text,
        TextSize               = 13,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Parent                 = mainBtn,
    })
    local arrow = create("TextLabel", {
        BackgroundTransparency = 1,
        AnchorPoint            = Vector2.new(1,0.5),
        Position               = UDim2.new(1,-10,0.5,0),
        Size                   = UDim2.fromOffset(10,10),
        FontFace               = FontFaceValue,
        Text                   = expanded and "⌃" or "⌄",
        TextColor3             = Theme.Muted,
        TextSize               = 12,
        Parent                 = mainBtn,
    })

    local subClip = create("Frame", {
        BackgroundTransparency = 1,
        Position               = UDim2.fromOffset(0,44),
        Size                   = UDim2.new(1,0,0,0),
        ClipsDescendants       = true,
        Parent                 = group,
    })
    local subHolder = create("Frame", {
        BackgroundTransparency = 1,
        Position               = UDim2.fromOffset(12,0),
        Size                   = UDim2.new(1,-12,0,0),
        AutomaticSize          = Enum.AutomaticSize.Y,
        Parent                 = subClip,
    })
    local subLayout = listLayout(subHolder, 4)
    local contentH  = 0

    local function recalc()
        contentH = subLayout.AbsoluteContentSize.Y
        local target = expanded and (44+contentH) or 36
        tween(group, MidTween, {Size=UDim2.new(1,0,0,target)})
        tween(subClip, MidTween, {Size=UDim2.new(1,0,0,expanded and contentH or 0)})
        arrow.Text = expanded and "⌃" or "⌄"
    end
    subLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(recalc)

    local api = {}
    function api:SetExpanded(s) expanded=s ; recalc() end
    function api:Toggle() api:SetExpanded(not expanded) end
    function api:AddSubButton(text, callback, tooltip)
        local sb = create("TextButton", {
            BackgroundColor3 = Theme.Surface2,
            BorderSizePixel  = 0,
            Size             = UDim2.new(1,0,0,30),
            Text             = "",
            AutoButtonColor  = false,
            Parent           = subHolder,
