local function tweenTowardTarget(target, maxDuration, speed)
    local rootPart = getRootPart()
    local targetCFrame = getTargetTransform(target)
    if not rootPart or not targetCFrame then
        return false
    end

    local distance = (rootPart.Position - targetCFrame.Position).Magnitude
    if distance <= 20 then
        return true
    end

    local duration = math.min(maxDuration or 2.5, distance / (speed or 120))
    local tween = TweenService:Create(rootPart,
        TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {
            CFrame = targetCFrame
        })

    local completed = false
    local connection
    connection = tween.Completed:Connect(function()
        completed = true
    end)

    tween:Play()

    local expiresAt = tick() + duration
    while autoFarmEnabled and tick() < expiresAt do
        if not rootPart.Parent then
            break
        end

        if isNearTarget(target, 22) then
            break
        end

        task.wait(0.05)
    end

    pcall(function()
        tween:Cancel()
    end)
    if connection then
        connection:Disconnect()
    end

    task.wait(0.1)
    return completed or isNearTarget(target, 22)
end

