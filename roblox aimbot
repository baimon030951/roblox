local function areUiObjectsOverlapping(a, b)
    if not a or not b then
        return false
    end

    local aPos = a.AbsolutePosition
    local aSize = a.AbsoluteSize
    local bPos = b.AbsolutePosition

    local topDiff = aPos.Y - bPos.Y
    local bottomDiff = bPos.Y - aPos.Y
    local leftDiff = aPos.X - bPos.X
    local rightDiff = bPos.X - aPos.X

    return topDiff < aSize.Y and bottomDiff < aSize.Y and leftDiff < aSize.X and rightDiff < aSize.X
end

local function isBarInsideDot(bar, dot)
    if not bar or not dot then
        return false
    end

    local barPos = bar.AbsolutePosition
    local barSize = bar.AbsoluteSize
    local dotPos = dot.AbsolutePosition
    local dotSize = dot.AbsoluteSize

    local barCenterX = barPos.X + (barSize.X / 2)
    local barCenterY = barPos.Y + (barSize.Y / 2)

    return barCenterX >= dotPos.X and barCenterX <= (dotPos.X + dotSize.X) and barCenterY >= dotPos.Y and barCenterY <=
               (dotPos.Y + dotSize.Y)
end

