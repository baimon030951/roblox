    local function getVP()
        local c=Workspace.CurrentCamera
        return c and c.ViewportSize or Vector2.new(1280,720)
    end
    local function maxSize()
        local v=getVP() ; local m=16
        return UDim2.fromOffset(
            math.max(window.MinSize.X, v.X-m*2),
            math.max(window.MinSize.Y, v.Y-m*2)
        )
    end

    function window:RefreshLayout()
        local sw = math.min(200, math.max(150, root.AbsoluteSize.X*0.22))
        searchBox.Size = UDim2.fromOffset(math.floor(sw+0.5), 26)
        updateSidebarSB()
    end

    makeDraggable(topbar, root)

    function window:SetVisible(state)
        window.Visible = state
        if state then
            root.Visible = true
            root.BackgroundTransparency = 1
            tween(root, MidTween, {
                BackgroundTransparency = 0,
                Size = window.Maximized and maxSize() or window.Size,
            })
        else
            tween(root, MidTween, {
                BackgroundTransparency = 1,
                Size = UDim2.fromOffset(root.AbsoluteSize.X-16, root.AbsoluteSize.Y-12),
            })
            task.delay(0.22, function() if root.Parent then root.Visible=false end end)
        end
    end
    function window:ToggleVisible() window:SetVisible(not window.Visible) end

    function window:SetMaximized(state)
        if state==window.Maximized then return end
        if state then
            window.RestoreSize=UDim2.fromOffset(root.AbsoluteSize.X,root.AbsoluteSize.Y)
            window.RestorePosition=root.Position
            window.Maximized=true
            tween(root, SlowTween, {Position=UDim2.fromScale(0.5,0.5), Size=maxSize()})
        else
            window.Maximized=false ; window.Size=window.RestoreSize
            tween(root, SlowTween, {Position=window.RestorePosition, Size=window.RestoreSize})
        end
    end

    function window:SelectTab(tab)
        for _, other in ipairs(window.Tabs) do
            other.Page.Visible = false
            tween(other.Button, SnapTween, {
                BackgroundColor3       = Theme.Sidebar,
                BackgroundTransparency = 1,
            })
            other.Button.TextLabel.TextColor3 = Theme.Subtext
            other.Button.IconLabel.TextColor3 = Theme.Muted
            if other.ScrollbarTrack then other.ScrollbarTrack.Visible=false end
        end
        window.CurrentTab = tab
        tab.Page.Visible  = true
        tween(tab.Button, SnapTween, {
            BackgroundColor3       = Theme.AccentLight,
            BackgroundTransparency = 0,
        })
        tab.Button.TextLabel.TextColor3 = Theme.Accent
        tab.Button.IconLabel.TextColor3 = Theme.Accent
        if tab.UpdateScrollbar then tab.UpdateScrollbar() end
    end

    function window:HighlightItem(item)
        local t = item.HighlightInstance or item.Instance
        if not t or not t.Parent then return end
        if t:IsA("Frame") or t:IsA("TextButton") or t:IsA("TextBox") then
            local orig = t.BackgroundColor3
            tween(t, SnapTween, {BackgroundColor3=Theme.AccentLight})
            task.delay(0.18, function()
                if t.Parent then tween(t, MidTween, {BackgroundColor3=orig}) end
            end)
        end
    end

    function window:FocusItem(tab, item)
        window:SelectTab(tab)
        task.defer(function()
            if tab.Page and item.Instance and item.Instance.Parent then
                if typeof(item.Reveal)=="function" then item.Reveal() end
                local ay = item.Instance.AbsolutePosition.Y - tab.Page.AbsolutePosition.Y + tab.Page.CanvasPosition.Y
                tab.Page.CanvasPosition = Vector2.new(0, math.max(ay-12,0))
                if tab.UpdateScrollbar then tab.UpdateScrollbar() end
                window:HighlightItem(item)
            end
        end)
    end

    function window:RunSearch(query)
        query = string.lower(query or "")
        if query=="" then window.LastSearchMiss=nil ; return end
        for _, tab in ipairs(window.Tabs) do
            for _, item in ipairs(tab.Items) do
                if item.SearchText:find(query,1,true) then
                    window.LastSearchMiss=nil
                    window:FocusItem(tab,item) ; return
                end
            end
        end
        if window.LastSearchMiss~=query then
            window.LastSearchMiss=query
            window.Library:Notify({Title="Search", Content="No results found", Duration=2})
        end
    end

    -- ── CreateTab ──────────────────────────────────────────
    function window:CreateTab(name, iconText)
        local tab = setmetatable({}, Tab)
        tab.Window = window ; tab.Name = name ; tab.Items = {}

        local btn = create("TextButton", {
            BackgroundColor3       = Theme.Sidebar,
            BackgroundTransparency = 1,
            BorderSizePixel        = 0,
            Size                   = UDim2.new(1,0,0,32),
            Text                   = "",
            AutoButtonColor        = false,
            Parent                 = tabList,
        })
        corner(btn, 7)
        ripple(btn)

        create("TextLabel", {
            Name                   = "IconLabel",
            BackgroundTransparency = 1,
            Position               = UDim2.fromOffset(10, 0),
            Size                   = UDim2.fromOffset(18, 32),
            FontFace               = FontFaceValue,
            Text                   = iconText or string.sub(name,1,1),
            TextColor3             = Theme.Muted,
            TextSize               = 12,
            Parent                 = btn,
        })
        create("TextLabel", {
            Name                   = "TextLabel",
            BackgroundTransparency = 1,
            Position               = UDim2.fromOffset(30, 0),
            Size                   = UDim2.new(1,-38,1,0),
            FontFace               = FontFaceValue,
            Text                   = name,
            TextColor3             = Theme.Subtext,
            TextSize               = 13,
            TextXAlignment         = Enum.TextXAlignment.Left,
            Parent                 = btn,
        })

        local page = create("ScrollingFrame", {
            Name             = name.."Frame",
            BackgroundTransparency = 1,
            BorderSizePixel  = 0,
            Size             = UDim2.fromScale(1,1),
            Visible          = false,
            CanvasSize       = UDim2.new(),
            Parent           = pageHost,
        })
        local pageBody = create("Frame", {
            BackgroundTransparency = 1,
            Size                   = UDim2.new(1,0,0,0),
            AutomaticSize          = Enum.AutomaticSize.Y,
            Parent                 = page,
        })
        local pageLayout = listLayout(pageBody, 8)
        pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            page.CanvasSize = UDim2.fromOffset(0, pageLayout.AbsoluteContentSize.Y+4)
        end)
        local pageTrack, _, updatePageSB = themedScrollbar(
            page, pageHost,
            UDim2.new(1,-4,0,2), UDim2.new(0,4,1,-4)
        )
        pageTrack.Visible = false

        tab.Button          = btn
        tab.Page            = page
        tab.PageBody        = pageBody
        tab.ScrollbarTrack  = pageTrack
        tab.UpdateScrollbar = updatePageSB

        function tab:RegisterItem(instance, searchText, highlightInstance, revealCallback)
            table.insert(tab.Items, {
                Instance          = instance,
                SearchText        = string.lower(searchText or ""),
                HighlightInstance = highlightInstance or instance,
                Reveal            = revealCallback,
            })
        end

        function tab:CreateSection(title)
            local section = setmetatable({}, Section)
            section.Tab = tab

            local card = create("Frame", {
                BackgroundColor3 = Theme.Surface,
                BorderSizePixel  = 0,
                Size             = UDim2.new(1,0,0,0),
                AutomaticSize    = Enum.AutomaticSize.Y,
                Parent           = pageBody,
            })
            corner(card, 10)
            stroke(card, Theme.Outline)
            pad(card, 12, 12, 12, 12)

            -- section header row
            local hRow = create("Frame", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1,0,0,16),
                Parent                 = card,
            })
            create("TextLabel", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1,0,1,0),
                FontFace               = FontFaceValue,
                Text                   = title:upper(),
                TextColor3             = Theme.Muted,
                TextSize               = 10,
                TextXAlignment         = Enum.TextXAlignment.Left,
                Parent                 = hRow,
            })

            local holder = create("Frame", {
                BackgroundTransparency = 1,
                Position               = UDim2.fromOffset(0, 22),
                Size                   = UDim2.new(1,0,0,0),
                AutomaticSize          = Enum.AutomaticSize.Y,
                Parent                 = card,
            })
            listLayout(holder, 6)

            section.Card   = card
            section.Holder = holder
            return section
        end

        btn.MouseEnter:Connect(function()
            if window.CurrentTab~=tab then
                tween(btn, SnapTween, {BackgroundColor3=Theme.Surface2, BackgroundTransparency=0})
            end
        end)
        btn.MouseLeave:Connect(function()
            if window.CurrentTab~=tab then
                tween(btn, SnapTween, {BackgroundColor3=Theme.Sidebar, BackgroundTransparency=1})
            end
        end)
        btn.MouseButton1Click:Connect(function() window:SelectTab(tab) end)

        table.insert(window.Tabs, tab)
        return tab
    end

    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        window:RunSearch(searchBox.Text)
    end)

    closeBtn.MouseButton1Click:Connect(function()
        tween(root, MidTween, {BackgroundTransparency=1, Size=UDim2.fromOffset(root.AbsoluteSize.X-16,root.AbsoluteSize.Y-12)})
        task.delay(0.22, function() if self.ScreenGui.Parent then self.ScreenGui:Destroy() end end)
    end)
    minimizeBtn.MouseButton1Click:Connect(function() window:ToggleVisible() end)
    maximizeBtn.MouseButton1Click:Connect(function() window:SetMaximized(not window.Maximized) end)

    UserInputService.InputBegan:Connect(function(input, gp)
        if not gp and input.KeyCode==window.ToggleKey then window:ToggleVisible() end
    end)

    -- resize handles
    local rsRight  = create("Frame",{Name="RSRight",  BackgroundTransparency=1,AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,0,0,10),Size=UDim2.new(0,6,1,-16),Parent=root})
    local rsBottom = create("Frame",{Name="RSBottom", BackgroundTransparency=1,AnchorPoint=Vector2.new(0,1),Position=UDim2.new(0,10,1,0), Size=UDim2.new(1,-16,0,6),Parent=root})
    local rsCorner = create("Frame",{Name="RSCorner", BackgroundTransparency=1,AnchorPoint=Vector2.new(1,1),Position=UDim2.new(1,0,1,0),  Size=UDim2.fromOffset(12,12),Parent=root})
    local rsState  = {Active=false,Mode=nil,SM=nil,SS=nil}
    local function beginRS(mode,input)
        if window.Maximized then window:SetMaximized(false) end
        rsState.Active=true;rsState.Mode=mode;rsState.SM=input.Position;rsState.SS=root.AbsoluteSize
    end
    for mode,h in pairs({Right=rsRight,Bottom=rsBottom,Corner=rsCorner}) do
        h.InputBegan:Connect(function(input)
            if input.UserInputType==Enum.UserInputType.MouseButton1 then beginRS(mode,input) end
        end)
    end
    UserInputService.InputChanged:Connect(function(input)
        if not rsState.Active or input.UserInputType~=Enum.UserInputType.MouseMovement then return end
        local d=input.Position-rsState.SM ; local w,h=rsState.SS.X,rsState.SS.Y
        if rsState.Mode=="Right"  or rsState.Mode=="Corner" then w=w+d.X end
        if rsState.Mode=="Bottom" or rsState.Mode=="Corner" then h=h+d.Y end
        w=math.max(window.MinSize.X,math.floor(w+0.5))
        h=math.max(window.MinSize.Y,math.floor(h+0.5))
        window.Size=UDim2.fromOffset(w,h) ; root.Size=window.Size
        window:RefreshLayout()
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 then rsState.Active=false end
    end)
    root:GetPropertyChangedSignal("AbsoluteSize"):Connect(function() window:RefreshLayout() end)
    Workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
        if window.Maximized then root.Size=maxSize() end
        window:RefreshLayout()
    end)

    tween(root, SlowTween, {Size=window.Size})
    window:RefreshLayout()
    return window
end

