local function solveMiniGame1(gui)
    if not autoMiniGame1Enabled then
        return
    end

    if miniGameActive or not gui or not gui.Parent then
        return
    end

    local bg = gui:FindFirstChild("BG")
    local main = bg and bg:FindFirstChild("Main")
    local clicker = main and main:FindFirstChild("Clicker")
    local barBg = bg and bg:FindFirstChild("BarBG")
    local bar = barBg and barBg:FindFirstChild("Bar")
    local dot = barBg and barBg:FindFirstChild("Dot")
    local remoteValue = gui:FindFirstChild("Remote")
    local keyValue = gui:FindFirstChild("Key")
    if not bg or not main or not clicker or not barBg or not bar or not dot or not remoteValue or not keyValue then
        return
    end

    miniGameActive = true
    clearMiniGameConnections()

    local solved = false
    local function finishMiniGame()
        clearMiniGameConnections()
        miniGameActive = false
    end

    local function trySolve()
        if solved or not gui.Parent then
            return
        end

        if isBarInsideDot(bar, dot) then
            solved = true
            activateGuiButton(clicker)
            pressEKey()
            task.delay(0.2, finishMiniGame)
        end
    end

    table.insert(miniGameConnections, RunService.RenderStepped:Connect(function()
        trySolve()
    end))

    table.insert(miniGameConnections, gui.AncestryChanged:Connect(function(_, parent)
        if not parent then
            finishMiniGame()
        end
    end))
end

local function solveMiniGame2(gui)
    if not autoMiniGame2Enabled then
        return
    end

    if miniGameActive or not gui or not gui.Parent then
        return
    end

    local frame = gui:FindFirstChild("Frame")
    local textLabel = gui:FindFirstChild("TextLabel")
    local remoteValue = gui:FindFirstChild("Remote")
    local keyValue = gui:FindFirstChild("Key")
    if not frame or not textLabel or not remoteValue or not keyValue then
        return
    end

    local remote = remoteValue.Value
    local key = keyValue.Value
    if typeof(remote) ~= "Instance" then
        return
    end

    miniGameActive = true
    clearMiniGameConnections()

    local function finishMiniGame()
        clearMiniGameConnections()
        miniGameActive = false
    end

    task.spawn(function()
        task.wait(7.65)
        if gui.Parent and miniGameActive then
            pcall(function()
                remote:FireServer(true, key)
            end)
        end
        task.wait(0.2)
        finishMiniGame()
    end)

    table.insert(miniGameConnections, gui.AncestryChanged:Connect(function(_, parent)
        if not parent then
            finishMiniGame()
        end
    end))
end

local function startMiniGameWatcher()
    if miniGameWatcherStarted then
