local function getPostProcessPart(jobName)
    local aMain = workspace:FindFirstChild("AMain")
    if not aMain or not jobName or jobName == "None" then
        return nil
    end

    local exactPackProcess = aMain:FindFirstChild(jobName .. "PackProcess", true)
    if exactPackProcess then
        return exactPackProcess
    end

    local exactProcess = aMain:FindFirstChild(jobName .. "Process", true)
    if exactProcess then
        return exactProcess
    end

    local loweredJobName = string.lower(jobName)
    local nearestJobProcess = nil
    local nearestJobDistance = math.huge
    local nearestAnyProcess = nil
    local nearestAnyDistance = math.huge

    for _, descendant in ipairs(aMain:GetDescendants()) do
        local loweredName = string.lower(descendant.Name)
        if string.find(loweredName, "process", 1, true) then
            local targetCFrame = getTargetTransform(descendant)
            if targetCFrame then
                local distance = getDistanceToTarget(descendant)

                if string.find(loweredName, loweredJobName, 1, true) and distance < nearestJobDistance then
                    nearestJobProcess = descendant
                    nearestJobDistance = distance
                end

                if distance < nearestAnyDistance then
                    nearestAnyProcess = descendant
                    nearestAnyDistance = distance
                end
            end
        end
    end

    return nearestJobProcess or nearestAnyProcess
end

