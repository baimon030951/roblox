	function Options:Notify(cfg)
		local notif = Clone(Components["Notification"])
		local title, desc = Options:GetLabels(notif)
		local timer = notif:FindFirstChild("Timer")

		SetProperty(title, { Text = cfg.Title,       Font = Enum.Font.GothamBold,     TextSize = Setup.FontSize.ComponentTitle, TextColor3 = Theme.Title })
		SetProperty(desc,  { Text = cfg.Description, Font = Enum.Font.Gotham,          TextSize = Setup.FontSize.Description,    TextColor3 = Theme.Description })
		SetProperty(notif, { Parent = Screen["Frame"], BackgroundColor3 = Theme.Component })

		local ns = notif:FindFirstChildOfClass("UIStroke")
		if ns then ns.Color = Theme.Outline end
		if timer then timer.BackgroundColor3 = Theme.Accent end

		task.spawn(function()
			local dur = cfg.Duration or 3
			Animations:Open(notif, Setup.Transparency, true)
			if timer then Tween(timer, dur, { Size = UDim2.new(0, 0, 0, 3) }) end
			task.wait(dur)
			Animations:Close(notif)
			task.wait(.3)
			notif:Destroy()
		end)
	end

