function Pulse:Notify(options)
    options = options or {}
    local note = create("Frame", {
        BackgroundColor3 = Theme.Surface,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 0, 58),
        Parent           = self.NotificationStack,
    })
    corner(note, 10)
    stroke(note, Theme.Outline)
    -- top border accent
    create("Frame", {
        BackgroundColor3 = options.Color or Theme.Accent,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 0, 2),
        Parent           = note,
    })
    local body = create("Frame", {
        BackgroundTransparency = 1,
        Position               = UDim2.fromOffset(0, 4),
        Size                   = UDim2.new(1, 0, 1, -4),
        Parent                 = note,
    })
    pad(body, 8, 8, 12, 12)
    create("TextLabel", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1, 0, 0, 14),
        FontFace               = FontFaceValue,
        Text                   = options.Title or "Notification",
        TextColor3             = Theme.Text,
        TextSize               = 12,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Parent                 = body,
    })
    create("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.fromOffset(0, 16),
        Size                   = UDim2.new(1, 0, 0, 24),
        FontFace               = FontFaceValue,
        Text                   = options.Content or "",
        TextColor3             = Theme.Subtext,
        TextSize               = 11,
        TextWrapped            = true,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Parent                 = body,
    })
    note.BackgroundTransparency = 1
    note.Size = UDim2.new(1,0,0,0)
    tween(note, MidTween, {BackgroundTransparency=0, Size=UDim2.new(1,0,0,58)})
    task.delay(options.Duration or 3, function()
        if not note.Parent then return end
        tween(note, FastTween, {BackgroundTransparency=1, Size=UDim2.new(1,0,0,0)})
        task.delay(0.2, function() if note.Parent then note:Destroy() end end)
    end)
end

