local function dexTeleportToTarget(target, attempts)
    local character = localPlayer and localPlayer.Character
    local rootPart = getRootPart()
    local targetCFrame, targetSize = getTargetTransform(target)
    if not character or not rootPart or not targetCFrame then
        return false
    end

    local yOffset = 3
    if targetSize then
        yOffset = math.max((targetSize.Y * 0.5) + 3, 3)
    end

    local destination = targetCFrame * CFrame.new(0, yOffset, 0)

    for _ = 1, (attempts or 6) do
        pcall(function()
            character:PivotTo(destination)
        end)
        rootPart.CFrame = destination
        rootPart.AssemblyLinearVelocity = Vector3.zero
        rootPart.AssemblyAngularVelocity = Vector3.zero
        task.wait(0.12)

        if (rootPart.Position - destination.Position).Magnitude <= 12 then
            return true
        end
    end

    return (rootPart.Position - destination.Position).Magnitude <= 16
end

