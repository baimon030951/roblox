local function parseNumericValue(value)
    if value == nil then
        return nil
    end

    if type(value) == "number" then
        return value
    end

    local numberText = tostring(value):gsub(",", ""):match("%-?%d+%.?%d*")
    return numberText and tonumber(numberText) or nil
end

local function getAttributeCaseInsensitive(instance, attributeName)
    if not instance or not attributeName then
        return nil, nil
    end

    local exactValue = instance:GetAttribute(attributeName)
    if exactValue ~= nil then
        return exactValue, attributeName
    end

    local loweredTarget = string.lower(attributeName)
    for name, value in pairs(instance:GetAttributes()) do
        if string.lower(name) == loweredTarget then
            return value, name
        end
    end

    return nil, nil
end

local function readMoneyFromInventoryNode(moneyNode)
    if not moneyNode then
        return nil, nil
    end

    local exactLowerValue = parseNumericValue(moneyNode:GetAttribute("value"))
    if exactLowerValue ~= nil then
        return exactLowerValue, "Inventory1.5.Money.value"
    end

    local attributeCandidates = {"value", "Value", "amount", "Amount", "Money", "money", "Cash", "cash"}

    for _, attributeName in ipairs(attributeCandidates) do
        local attributeValue, resolvedName = getAttributeCaseInsensitive(moneyNode, attributeName)
        local parsedValue = parseNumericValue(attributeValue)
        if parsedValue ~= nil then
            return parsedValue, "Inventory1.5.Money." .. tostring(resolvedName)
        end
    end

    if moneyNode:IsA("ValueBase") then
        local parsedValue = parseNumericValue(moneyNode.Value)
        if parsedValue ~= nil then
            return parsedValue, "Inventory1.5.Money.ValueBase"
        end
    end

    for _, descendant in ipairs(moneyNode:GetDescendants()) do
        for _, attributeName in ipairs(attributeCandidates) do
            local attributeValue, resolvedName = getAttributeCaseInsensitive(descendant, attributeName)
            local parsedValue = parseNumericValue(attributeValue)
            if parsedValue ~= nil then
                return parsedValue, "Inventory1.5.Money.Descendant." .. tostring(resolvedName)
            end
        end

        if descendant:IsA("ValueBase") then
            local parsedValue = parseNumericValue(descendant.Value)
            if parsedValue ~= nil then
                return parsedValue, "Inventory1.5.Money.Descendant.ValueBase"
            end
        end

        if descendant:IsA("TextLabel") or descendant:IsA("TextButton") then
            local parsedValue = parseNumericValue(descendant.Text)
            if parsedValue ~= nil then
                return parsedValue, "Inventory1.5.Money.Descendant.Text"
            end
        end
    end

    return nil, nil
end

local function readMoneyValueFromInstance(root)
    if not root then
        return nil
    end

    local candidateNames = {"Money", "Cash", "Wallet", "Balance", "Coins", "Coin", "Baht", "Bucks"}

    for _, name in ipairs(candidateNames) do
        local exact = root:FindFirstChild(name)
        if exact and exact:IsA("ValueBase") then
            local value = parseNumericValue(exact.Value)
            if value ~= nil then
                return value, exact.Name
            end
        end
    end

    for _, child in ipairs(root:GetChildren()) do
        for _, name in ipairs(candidateNames) do
            if string.lower(child.Name) == string.lower(name) and child:IsA("ValueBase") then
                local value = parseNumericValue(child.Value)
                if value ~= nil then
                    return value, child.Name
                end
            end
        end
    end

    local attributes = root:GetAttributes()
    for attributeName, attributeValue in pairs(attributes) do
        for _, name in ipairs(candidateNames) do
            if string.lower(attributeName) == string.lower(name) then
                local value = parseNumericValue(attributeValue)
                if value ~= nil then
                    return value, attributeName
                end
            end
        end
    end

    return nil, nil
end

local function resolveInventoryMoneyNode()
    local inventoryGui = playerGui and playerGui:FindFirstChild("Inventory1.5")
    local inventoryFrame = inventoryGui and inventoryGui:FindFirstChild("Frame")
    local inventoryMain = inventoryFrame and inventoryFrame:FindFirstChild("Main")
    local inventoryScrollingFrame = inventoryMain and inventoryMain:FindFirstChild("ScrollingFrame")
    local inventoryScrolling = inventoryScrollingFrame and inventoryScrollingFrame:FindFirstChild("Scrolling")

    return inventoryGui, inventoryScrolling and inventoryScrolling:FindFirstChild("Money")
end

local function getCurrentMoneyAmount()
    local inventoryGui, moneyNode = resolveInventoryMoneyNode()
    for _ = 1, 10 do
        if moneyNode then
            local parsedValue, sourceName = readMoneyFromInventoryNode(moneyNode)
            if parsedValue ~= nil then
                return parsedValue, sourceName
            end
        end

        task.wait(0.15)
        inventoryGui, moneyNode = resolveInventoryMoneyNode()
    end

    if inventoryGui then
        for _, descendant in ipairs(inventoryGui:GetDescendants()) do
            if descendant.Name == "Money" then
                local parsedValue, sourceName = readMoneyFromInventoryNode(descendant)
                if parsedValue ~= nil then
                    return parsedValue, sourceName
                end
            end
        end
    end

    local containers = {localPlayer and localPlayer:FindFirstChild("leaderstats"),
                        localPlayer and localPlayer:FindFirstChild("Status"),
                        localPlayer and localPlayer:FindFirstChild("Data"), localPlayer}

    for _, container in ipairs(containers) do
        local value, sourceName = readMoneyValueFromInstance(container)
        if value ~= nil then
            return value, sourceName
        end
    end

    if localPlayer then
        for _, descendant in ipairs(localPlayer:GetDescendants()) do
            local value, sourceName = readMoneyValueFromInstance(descendant)
            if value ~= nil then
                return value, sourceName
            end
        end
    end

    return nil, nil
end

local function formatMoneyAmount(value)
    if value == nil then
        return "Unknown"
    end

    local sign = value < 0 and "-" or ""
    local whole = tostring(math.floor(math.abs(value)))
    local formatted = whole

    while true do
        local replaced
        formatted, replaced = formatted:gsub("^(-?%d+)(%d%d%d)", "%1,%2")
        if replaced == 0 then
            break
        end
    end

    return sign .. formatted
end

