    while autoFarmEnabled and tick() < expiresAt do
        local currentSnapshot = getInventorySnapshot()
        local bestName = nil
        local bestDelta = 0
        local fallbackAppeared = false
        local relatedAlternateName = nil
        local relatedAlternateCount = 0

        for itemName, currentCount in pairs(currentSnapshot) do
            local previousCount = beforeSnapshot[itemName] or 0
            local delta = currentCount - previousCount
            local loweredItemName = string.lower(itemName)

            if itemName == fallbackItemName and currentCount > 0 then
                fallbackAppeared = true
            end

            if delta > 0 and itemName ~= farmItemName then
                local score = delta
                if loweredFarmItemName ~= "" and string.find(loweredItemName, loweredFarmItemName, 1, true) then
                    score = score + 1000
                end
                if itemName == fallbackItemName then
                    score = score + 500
                end

                if score > bestDelta then
                    bestDelta = score
                    bestName = itemName
                end
            end

            if loweredFarmItemName ~= "" and itemName ~= farmItemName and currentCount > 0 then
                if string.find(loweredItemName, loweredFarmItemName, 1, true) then
                    if currentCount > relatedAlternateCount then
                        relatedAlternateCount = currentCount
                        relatedAlternateName = itemName
                    end
                end
            end
        end

        if bestName then
            return bestName
        end

        if relatedAlternateName then
            return relatedAlternateName
        end

        if fallbackAppeared and fallbackItemName ~= farmItemName then
            return fallbackItemName
        end

        task.wait(0.2)
    end

    return nil
end

local function buildFallbackSellerItemName(postPart)
    local fallbackName = tostring(postPart and postPart.Name or "")
    fallbackName = string.gsub(fallbackName, "PackProcess$", "")
    fallbackName = string.gsub(fallbackName, "Process$", "")
    return fallbackName
end

local function openPostProcessInteraction(postPart)
    for attempt = 1, 4 do
        debugAutoFarm("openPostProcessInteraction attempt=" .. tostring(attempt) .. " target=" ..
                          tostring(postPart and postPart.Name))
        if dexTeleportToTarget(postPart, 10) then
            beginHoldEKey()
            local ready = waitForProcessReady(5.5)
            endHoldEKey()

            if ready then
                task.wait(0.25)
                if isProcessGuiOpen() then
                    return true
                end
            end
        else
            debugAutoFarm("openPostProcessInteraction failed to reach target")
        end

        task.wait(0.45)
    end

    return false
end

local function confirmPostedSellerItem(farmItemName, fallbackItemName, beforeSnapshot, timeout, unloadCount)
    local sellerItemName = resolvePostedSellerItemName(farmItemName, fallbackItemName, beforeSnapshot, timeout or 6)
    if not sellerItemName or sellerItemName == "" or sellerItemName == farmItemName then
        sellerItemName = nil
    end

    if sellerItemName and getInventoryItemCount(sellerItemName) > 0 then
        return sellerItemName
    end

    if fallbackItemName and fallbackItemName ~= "" and fallbackItemName ~= farmItemName then
        local farmItemGone = waitForInventoryItemGone(farmItemName, 0.6, 2.5)
        local beforeCount = tonumber(beforeSnapshot and beforeSnapshot[farmItemName]) or 0
        local currentCount = getInventoryItemCount(farmItemName)
        local farmItemReduced = currentCount < beforeCount

        if farmItemGone or farmItemReduced or (unloadCount or 0) >= 3 then
            return fallbackItemName
        end
    end

    return nil
end

local function sellPostedItems(itemName)
    if not itemName or itemName == "" then
        debugAutoFarm("sellPostedItems aborted: missing itemName")
        return false
    end

    local moneyBeforeSell = getCurrentMoneyAmount()

    debugAutoFarm("sellPostedItems start for " .. tostring(itemName))

    local sellerTarget = getPostSellerPart(itemName)
    local sellerDestination = CFrame.new(397.6261291503906, 65.84611511230469, -892.1386108398438)

    if sellerTarget then
        if not dexTeleportToTarget(sellerTarget, 10) then
            debugAutoFarm("sellPostedItems failed: dexTeleportToTarget returned false")
            return false
        end
    else
        if not dexTeleportToCFrame(sellerDestination, 10) then
            debugAutoFarm("sellPostedItems failed: dexTeleportToCFrame returned false")
            return false
        end
    end

    debugAutoFarm("sellPostedItems teleported to seller destination")

    debugAutoFarm("sellPostedItems opening seller ui until ECONOMY appears")
    local economyGui, remoteEvent = openSellerUiUntilReady(sellerTarget, sellerDestination, 12)

    if not remoteEvent then
        debugAutoFarm("sellPostedItems failed: ECONOMY remote not ready")
        if economyGui then
            economyGui.Enabled = false
        end
        return false
    end

    debugAutoFarm("sellPostedItems remote ready")

    local depletedCount = 0
    local sellSucceeded = false
    local timeoutAt = tick() + 45
    while autoFarmEnabled and tick() < timeoutAt do
        local itemExists = hasInventoryItem(itemName)
        local itemCount = getInventoryItemCount(itemName)
        if not itemExists or itemCount <= 0 then
            depletedCount = depletedCount + 1
            if depletedCount >= 4 then
                debugAutoFarm("sellPostedItems complete: item depleted from inventory")
                sellSucceeded = true
                break
            end
        else
            depletedCount = 0
        end

        local sellAmount = math.clamp(itemCount, 1, 10)

        pcall(function()
            remoteEvent:FireServer("Seller", itemName, sellAmount)
        end)
        debugAutoFarm("sellPostedItems fired Seller for " .. tostring(itemName) .. " x" .. tostring(sellAmount))
        task.wait(0.3)
    end

    if economyGui then
        economyGui.Enabled = false
    end

    if not sellSucceeded and isInventoryItemDepleted(itemName) then
        sellSucceeded = true
    end

    if sellSucceeded then
        task.spawn(function()
            pcall(function()
                sendSellWebhook(itemName, moneyBeforeSell)
            end)
        end)
    end

    debugAutoFarm("sellPostedItems end")
    return sellSucceeded
end

local function processFullInventory()
    local postPart = getPostProcessPart(selectedFarmJob)
    local farmItemName = getFarmPackName(selectedFarmJob)
    if not postPart or not farmItemName then
        debugAutoFarm("processFullInventory aborted: missing postPart or farmItemName")
        inventoryFullDetected = false
        return false
    end

    debugAutoFarm("processFullInventory start for job=" .. tostring(selectedFarmJob) .. " farmItem=" ..
                      tostring(farmItemName))
    autoFarmPostingInProgress = true

    pcall(function()
        game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("Farm"):FireServer("Stop")
    end)

    local fallbackSellerItemName = buildFallbackSellerItemName(postPart)
    local sellerItemName = nil

    for attempt = 1, 3 do
        local inventorySnapshotBeforePost = getInventorySnapshot()
        debugAutoFarm("processFullInventory GO_POST attempt=" .. tostring(attempt) .. " using=" ..
                          tostring(postPart.Name))

        if not openPostProcessInteraction(postPart) then
            debugAutoFarm("processFullInventory post interaction did not stay open")
            task.wait(0.5)
        else
            local unloadUntil = tick() + 12
            local unloadCount = 0
            local lastActiveAt = tick()

            while autoFarmEnabled and tick() < unloadUntil do
                if isProcessGuiOpen() then
                    lastActiveAt = tick()
                elseif unloadCount > 0 and (tick() - lastActiveAt) > 1 then
                    debugAutoFarm("processFullInventory process interaction dropped before confirmation")
                    break
                end

                if unloadTruckPostItem(farmItemName) then
                    unloadCount = unloadCount + 1
                    debugAutoFarm("processFullInventory unload pulse=" .. tostring(unloadCount))
                end

                task.wait(0.2)
            end

            debugAutoFarm("processFullInventory finished unload phase count=" .. tostring(unloadCount))

            sellerItemName = confirmPostedSellerItem(farmItemName, fallbackSellerItemName, inventorySnapshotBeforePost,
                6, unloadCount)

            if sellerItemName then
                debugAutoFarm("processFullInventory confirmed posted seller item=" .. tostring(sellerItemName))
                break
            end

            debugAutoFarm("processFullInventory did not confirm post result, retrying post instead of selling")
            task.wait(0.6)
        end
    end

    if not sellerItemName then
        debugAutoFarm("processFullInventory aborted: could not confirm posted item before sell")
        inventoryFullDetected = false
        autoFarmPostingInProgress = false
        return false
    end

    debugAutoFarm("processFullInventory calling sellPostedItems for " .. tostring(sellerItemName))
    sellPostedItems(sellerItemName)

    inventoryFullDetected = false
    autoFarmPostingInProgress = false
    debugAutoFarm("processFullInventory end")
    return true
end

