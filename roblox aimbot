	function Options:AddTab(cfg)
		-- [Fix 13]
		if StoredInfo.Tabs[cfg.Title] then
			error(("[UI] Tab '%s' ถูกสร้างซ้ำ"):format(tostring(cfg.Title)))
		end

		local ex, mainEx = Examples["TabButtonExample"], Examples["MainExample"]
		local main   = Clone(mainEx)
		local tabBtn = Clone(ex)

		local ico = tabBtn:FindFirstChild("ICO")
		if cfg.Icon and ico then
			SetProperty(ico, { Image = cfg.Icon })
		elseif ico then
			Destroy(ico)
		end

		StoredInfo.Tabs[cfg.Title] = { tabBtn }

		local lbl = tabBtn:FindFirstChild("TextLabel")
		if lbl then
			SetProperty(lbl, {
				Text       = cfg.Title,
				TextColor3 = Theme.Tab,
				Font       = Enum.Font.GothamSemibold,
				TextSize   = Setup.FontSize.Tab,
			})
		end

		SetProperty(main,   { Parent = mainEx.Parent, Name = cfg.Title })
		SetProperty(tabBtn, {
			Parent      = ex.Parent,
			LayoutOrder = StoredInfo.Sections[cfg.Section] or (#StoredInfo.Sections + 1),
			Name        = cfg.Title,
			Visible     = true,
		})

		Connect(tabBtn.MouseButton1Click, function()
			Options:SetTab(tabBtn.Name)
		end)

		-- [Fix 8] เปิด tab แรกอัตโนมัติ
		if FirstTab then
			FirstTab = false
			task.defer(function() Options:SetTab(cfg.Title) end)
		end

		return main.ScrollingFrame
	end

