-- CreateWindow — macOS compact 750×480
-- ============================================================
function Pulse:CreateWindow(options)
    options = options or {}

    local window = setmetatable({}, Window)
    window.Library         = self
    window.Title           = options.Title or "Dashboard"
    window.ToggleKey       = options.ToggleKey or Enum.KeyCode.RightControl
    window.Size            = options.Size or UDim2.fromOffset(750, 480)
    window.MinSize         = options.MinSize or Vector2.new(620, 400)
    window.Visible         = true
    window.Maximized       = false
    window.RestoreSize     = window.Size
    window.RestorePosition = UDim2.fromScale(0.5, 0.5)
    window.Tabs            = {}
    window.CurrentTab      = nil
    window.LastSearchMiss  = nil

    self:_createLoading(window.Title)

    -- ROOT
    local root = create("Frame", {
        Name             = "MainWindow",
        AnchorPoint      = Vector2.new(0.5,0.5),
        Position         = UDim2.fromScale(0.5,0.5),
        Size             = UDim2.fromOffset(
            window.Size.X.Offset - 20,
            window.Size.Y.Offset - 16
        ),
        BackgroundColor3 = Theme.Background,
        BorderSizePixel  = 0,
        Parent           = self.ScreenGui,
    })
    corner(root, 12)
    stroke(root, Theme.Outline)
    macShadow(root)
    window.Root = root
    create("UISizeConstraint", {MinSize=window.MinSize, Parent=root})

    -- ── TOPBAR ─────────────────────────────────────────────
    local topbar = create("Frame", {
        BackgroundColor3 = Theme.Topbar,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1,0,0,44),
        Parent           = root,
    })
    corner(topbar, 12)
    -- fill bottom corners
    create("Frame", {
        BackgroundColor3 = Theme.Topbar,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0,0,1,-12),
        Size             = UDim2.new(1,0,0,12),
        Parent           = topbar,
    })
    -- bottom separator line
    create("Frame", {
        BackgroundColor3 = Theme.Outline,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0,0,1,-1),
        Size             = UDim2.new(1,0,0,1),
        Parent           = topbar,
    })

    -- traffic lights (macOS style)
    local tlFrame = create("Frame", {
        BackgroundTransparency = 1,
        Position               = UDim2.fromOffset(14, 0),
        Size                   = UDim2.fromOffset(72, 44),
        Parent                 = topbar,
    })
    local tlLayout = listLayout(tlFrame, 7, true)
    tlLayout.VerticalAlignment = Enum.VerticalAlignment.Center

    local function trafficLight(color)
        local btn = create("TextButton", {
            BackgroundColor3 = color,
            BorderSizePixel  = 0,
            Size             = UDim2.fromOffset(13, 13),
            Text             = "",
            AutoButtonColor  = false,
            Parent           = tlFrame,
        })
        corner(btn, 999)
        -- subtle ring
        stroke(btn, Color3.fromRGB(0,0,0), 0.82, 1)
        -- hover: brightness down
        btn.MouseEnter:Connect(function()
            tween(btn, SnapTween, {BackgroundTransparency=0.2})
        end)
        btn.MouseLeave:Connect(function()
            tween(btn, SnapTween, {BackgroundTransparency=0})
        end)
        return btn
    end

    local closeBtn    = trafficLight(Theme.CloseColor)
    local minimizeBtn = trafficLight(Theme.MinColor)
    local maximizeBtn = trafficLight(Theme.MaxColor)

